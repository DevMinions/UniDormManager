# ============================================
# Web 前端环境变量样例
# 复制为 .env.local 后填入你的值（.env.local 已被 .gitignore 排除）
# ============================================

# 后端 API 基础 URL
# 开发：直接指向本地后端
#   VITE_API_URL=http://localhost:8080
# 通过 docker-compose 启动时无需设置（走 nginx 反代到 /api）
# 生产：填你的对外域名 + /api 前缀
#   VITE_API_URL=https://your-domain.com
VITE_API_URL=http://localhost:8080

# Google Gemini AI 助手（可选；不需要 AI 功能可留空）
GEMINI_API_KEY=
