{
  "name": "unidorm-manager-optimized",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "build:analyze": "tsc && vite build && npx vite-bundle-analyzer dist/stats.html",
    "preview": "vite preview --host",
    "build:production": "npm run build && npm run optimize:images",
    "optimize:images": "npx imagemin dist/**/*.{png,jpg,jpeg,gif,svg} --out-dir=dist",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "performance:audit": "npx lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-report.json"
  },
  "dependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.10.1",
    "lucide-react": "^0.555.0",
    "recharts": "^3.5.1",
    "@google/genai": "^1.31.0",
    "react-intersection-observer": "^9.5.3",
    "react-window": "^1.8.8",
    "react-window-infinite-loader": "^1.0.9",
    "web-vitals": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-imagemin": "^0.6.1",
    "rollup-plugin-visualizer": "^5.9.2",
    "terser": "^5.27.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "prettier": "^3.2.5",
    "@types/react-window": "^1.8.8",
    "@types/react-window-infinite-loader": "^1.0.9",
    "vitest": "^1.3.1",
    "@testing-library/react": "^14.2.1",
    "@testing-library/jest-dom": "^6.4.2",
    "jsdom": "^24.0.0",
    "imagemin": "^8.0.1",
    "imagemin-pngquant": "^10.0.0",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-svgo": "^10.0.1",
    "lighthouse": "^11.7.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}