# ============================================
# 后端 / docker-compose 环境变量样例
# 复制此文件为 .env 后填入你的值。.env 已被 .gitignore 排除。
# ============================================

# ============================================
# PostgreSQL 数据库
# ============================================
POSTGRES_DB=unidorm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=please_change_me_postgres
POSTGRES_PORT=5432

# ============================================
# Redis 缓存
# ============================================
REDIS_PASSWORD=please_change_me_redis
REDIS_PORT=6379
# USE_CACHE=true 启用 Redis；false 时后端跳过缓存层
USE_CACHE=true

# ============================================
# 应用配置
# ============================================
APP_ENV=production
APP_PORT=8080
BACKEND_PORT=8080
FRONTEND_PORT=80

# JWT 签名密钥（生产必须 >= 32 字符随机强密码）
JWT_SECRET=please_change_me_to_a_strong_random_string_at_least_32_chars

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# 默认管理员账号
# ============================================
# 留空则后端首次启动时随机生成一个 16 字符密码并打印到日志（只打印一次，请立刻记录）
# 设置后则用此值作为初始 admin 密码（仅首次创建生效，不会覆盖已有 admin）
ADMIN_INITIAL_PASSWORD=

# ============================================
# Nginx 反向代理（仅当启用 production profile 时用到）
# ============================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
