# ============================================
# UniDormManager 项目 .gitignore
# ============================================

# ---> Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/
go.work

# ---> Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ---> 构建输出
dist/
build/
.unpackage/
release/

# ---> 日志文件
logs/
*.log

# ---> 临时文件
*.tmp
*.temp
*.cache
.cache/
*.pid
*.seed
*.pid.lock

# ---> 编辑器/IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ---> 测试相关
coverage/
.nyc_output/
playwright-report/
test-results/
e2e-report/

# ---> 环境配置（包含敏感信息）
.env
.env.local
.env.*.local

# ---> 上传文件/静态资源（应该由服务器管理或通过其他方式同步）
uploads/
!uploads/.gitkeep

# ---> 数据库文件
*.db
*.sqlite
*.sqlite3

# ---> Docker
*.env.docker

# ---> 其他
*.bak
*.backup
Thumbs.db
