/** Empty 空状态组件样式 **/

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 60rpx;
  box-sizing: border-box;
}

.empty-container.with-bg {
  background-color: #f5f5f5;
  border-radius: 16rpx;
}

/* 图标 */
.empty-icon-wrap {
  margin-bottom: 32rpx;
}

.empty-icon-emoji {
  font-size: 120rpx;
  line-height: 1;
}

.empty-icon-img {
  width: 200rpx;
  height: 200rpx;
}

/* 标题 */
.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
  text-align: center;
}

/* 描述 */
.empty-description {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

/* 操作按钮 */
.empty-action {
  margin-top: 8rpx;
}

.empty-btn {
  min-width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  padding: 0 48rpx;
  text-align: center;
}

.empty-btn.primary {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  color: #fff;
}

.empty-btn.primary::after {
  border: none;
}

.empty-btn.default {
  background-color: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}

.empty-btn.warn {
  background-color: #ff4d4f;
  color: #fff;
}

.empty-btn.warn::after {
  border: none;
}
