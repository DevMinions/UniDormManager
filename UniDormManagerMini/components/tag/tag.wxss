/** Tag 标签组件样式 **/

/* 基础样式 */
.tag {
  display: inline-flex;
  align-items: center;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  white-space: nowrap;
  line-height: 1.5;
  transition: all 0.2s ease;
  position: relative;
}

/* ========== 尺寸 ========== */
.tag-small {
  font-size: 22rpx;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 6rpx;
}

.tag-medium {
  font-size: 26rpx;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
}

.tag-large {
  font-size: 30rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 10rpx;
}

/* 圆角样式 */
.tag-round {
  border-radius: 999rpx !important;
}

/* ========== 颜色主题 ========== */

/* 蓝色 */
.tag-blue {
  background-color: #e6f7ff;
  border-color: #91d5ff;
  color: #1890ff;
}

.tag-blue.tag-plain {
  background-color: transparent;
  border-color: #1890ff;
  color: #1890ff;
}

/* 绿色 */
.tag-green {
  background-color: #f6ffed;
  border-color: #b7eb8f;
  color: #52c41a;
}

.tag-green.tag-plain {
  background-color: transparent;
  border-color: #52c41a;
  color: #52c41a;
}

/* 红色 */
.tag-red {
  background-color: #fff1f0;
  border-color: #ffa39e;
  color: #ff4d4f;
}

.tag-red.tag-plain {
  background-color: transparent;
  border-color: #ff4d4f;
  color: #ff4d4f;
}

/* 橙色 */
.tag-orange {
  background-color: #fff7e6;
  border-color: #ffd591;
  color: #fa8c16;
}

.tag-orange.tag-plain {
  background-color: transparent;
  border-color: #fa8c16;
  color: #fa8c16;
}

/* 紫色 */
.tag-purple {
  background-color: #f9f0ff;
  border-color: #d3adf7;
  color: #722ed1;
}

.tag-purple.tag-plain {
  background-color: transparent;
  border-color: #722ed1;
  color: #722ed1;
}

/* 灰色 */
.tag-gray {
  background-color: #f5f5f5;
  border-color: #d9d9d9;
  color: #666;
}

.tag-gray.tag-plain {
  background-color: transparent;
  border-color: #999;
  color: #999;
}

/* 黑色 */
.tag-black {
  background-color: #fafafa;
  border-color: #d9d9d9;
  color: #333;
}

.tag-black.tag-plain {
  background-color: transparent;
  border-color: #333;
  color: #333;
}

/* ========== 关闭按钮 ========== */
.tag-close {
  margin-left: 8rpx;
  padding: 0 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 32rpx;
  line-height: 1;
  opacity: 0.6;
  transition: opacity 0.2s ease;
}

.tag-close:active .close-icon {
  opacity: 1;
}
