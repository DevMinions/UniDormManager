/** Badge 徽标组件样式 **/

.badge-wrap {
  position: relative;
  display: inline-block;
}

/* 徽标基础样式 */
.badge {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

/* ========== 位置 ========== */
.badge-top-right {
  top: 0;
  right: 0;
  transform: translate(50%, -50%);
  transform-origin: 100% 0;
}

.badge-top-left {
  top: 0;
  left: 0;
  transform: translate(-50%, -50%);
  transform-origin: 0 0;
}

.badge-bottom-right {
  bottom: 0;
  right: 0;
  transform: translate(50%, 50%);
  transform-origin: 100% 100%;
}

.badge-bottom-left {
  bottom: 0;
  left: 0;
  transform: translate(-50%, 50%);
  transform-origin: 0 100%;
}

/* ========== 数字徽标 ========== */
.badge:not(.badge-dot) {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: 16rpx;
  background-color: #ff4d4f;
  box-shadow: 0 0 0 2rpx #fff;
}

.badge-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1;
}

/* ========== 圆点徽标 ========== */
.badge-dot {
  width: 16rpx;
  height: 16rpx;
  background-color: #ff4d4f;
  border-radius: 50%;
  box-shadow: 0 0 0 2rpx #fff;
}

.badge-dot .dot {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: inherit;
}

/* ========== 特殊样式 ========== */

/* 较大数字的padding调整 */
.badge:has(.badge-text) {
  box-sizing: border-box;
}
