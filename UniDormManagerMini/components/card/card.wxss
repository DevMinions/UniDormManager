/** Card 卡片组件样式 **/

/* 基础样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-sizing: border-box;
  position: relative;
}

/* ========== 卡片类型 ========== */

/* 默认类型 - 白色背景 */
.card-default {
  background-color: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 边框类型 - 简洁边框 */
.card-bordered {
  background-color: #fff;
  border: 2rpx solid #e8e8e8;
}

.card-bordered.no-border {
  border: none;
}

/* 阴影类型 - 明显阴影 */
.card-shadow {
  background-color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* 简洁类型 - 无阴影无边框 */
.card-plain {
  background-color: #f5f5f5;
}

/* ========== Hover 效果 ========== */
.card-hoverable {
  transition: all 0.2s ease;
}

.card-hoverable.card-hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

/* ========== 头部 ========== */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 0;
  min-height: 72rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-header-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ========== 内容区域 ========== */
.card-body {
  box-sizing: border-box;
}

/* ========== 底部 ========== */
.card-footer {
  padding: 0 24rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

/* 没有header时的footer样式 */
.card > view:last-child:not(.card-header):not(.card-body) {
  padding: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}
