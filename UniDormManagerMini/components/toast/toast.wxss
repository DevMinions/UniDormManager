/** Toast 轻提示组件样式 **/

/* 容器 */
.toast-container {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
  pointer-events: none;
}

.toast-top {
  align-items: flex-start;
  padding-top: 200rpx;
}

.toast-center {
  align-items: center;
}

.toast-bottom {
  align-items: flex-end;
  padding-bottom: 200rpx;
}

/* 遮罩层 */
.toast-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  pointer-events: auto;
}

/* 提示内容 */
.toast-content {
  pointer-events: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  min-width: 280rpx;
  max-width: 600rpx;
  padding: 32rpx 40rpx;
  border-radius: 16rpx;
  background-color: rgba(0, 0, 0, 0.8);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(10px);
}

/* ========== 不同类型的样式 ========== */
.toast-content.toast-success .icon-text {
  color: #52c41a;
}

.toast-content.toast-error .icon-text {
  color: #ff4d4f;
}

.toast-content.toast-warning .icon-text {
  color: #fa8c16;
}

.toast-content.toast-info .icon-text {
  color: #1890ff;
}

.toast-content.toast-loading .loading-icon {
  color: #1890ff;
  font-size: 40rpx;
  animation: loading-spin 1s linear infinite;
  display: inline-block;
}

@keyframes loading-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ========== 图标 ========== */
.toast-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 48rpx;
  font-weight: bold;
  line-height: 1;
}

/* ========== 消息 ========== */
.toast-message {
  font-size: 28rpx;
  color: #fff;
  text-align: center;
  line-height: 1.6;
  word-wrap: break-word;
}
