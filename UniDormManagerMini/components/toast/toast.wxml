<!-- 
  Toast 轻提示组件
  使用示例：
  <toast id="toast" />
  
  在页面 js 中调用：
  this.selectComponent('#toast').show({
    message: '操作成功',
    type: 'success',
    duration: 2000
  });
-->
<view wx:if="{{show}}" class="toast-container toast-{{position}}" catchtap="onMaskTap">
  <!-- 遮罩层 -->
  <view wx:if="{{mask}}" class="toast-mask" catchtap="onMaskTap"></view>
  
  <!-- 提示内容 -->
  <view class="toast-content toast-{{type}}">
    <!-- 图标 -->
    <view wx:if="{{icon}}" class="toast-icon">
      <text wx:if="{{type === 'loading'}}" class="loading-icon">⟳</text>
      <text wx:else class="icon-text">{{iconMap[type]}}</text>
    </view>
    
    <!-- 文字 -->
    <view class="toast-message">{{message}}</view>
  </view>
</view>
