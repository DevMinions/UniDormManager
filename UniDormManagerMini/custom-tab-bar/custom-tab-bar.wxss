/* 自定义 TabBar 样式 */
.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-top: 1rpx solid var(--gray-200);
  z-index: 9999;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  /* 调试：红色边框 */
  border: 4rpx solid red !important;
}

.tabbar-container {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
  padding: 0 20rpx;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  padding: 8rpx 0;
  transition: all 0.2s ease;
}

.tabbar-item:active {
  opacity: 0.7;
}

.tabbar-icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 4rpx;
}

.tabbar-icon {
  width: 48rpx;
  height: 48rpx;
  transition: transform 0.2s ease;
}

.tabbar-item.active .tabbar-icon {
  transform: scale(1.1);
}

.tabbar-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1;
  transition: color 0.2s ease;
}

.tabbar-item.active .tabbar-text {
  color: var(--primary-color);
  font-weight: 600;
}

/* 选中态渐变效果 */
.tabbar-item.active {
  position: relative;
}

.tabbar-item.active::after {
  content: '';
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: var(--primary-gradient);
  border-radius: 2rpx;
}

/* 安全区域 */
.tabbar-safe-area {
  background: #ffffff;
}

/* 适配 iPhone X+ 底部安全区 */
@supports (bottom: constant(safe-area-inset-bottom)) {
  .custom-tabbar {
    padding-bottom: constant(safe-area-inset-bottom);
  }
}

@supports (bottom: env(safe-area-inset-bottom)) {
  .custom-tabbar {
    padding-bottom: env(safe-area-inset-bottom);
  }
}

/* 页面内容需要添加底部 padding 以避免被 TabBar 遮挡 */
.page-with-custom-tabbar {
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}
