<!--pages/checkin/index/index.wxml-->
<view class="container">
  
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-icon">📝</text>
    <view class="header-content">
      <text class="header-title">办理入住</text>
      <text class="header-desc">为新学生办理宿舍入住手续</text>
    </view>
  </view>

  <!-- 入住表单 -->
  <view class="form-card">
    
    <!-- 学生信息 -->
    <view class="form-section">
      <view class="section-title">学生信息</view>
      
      <view class="form-item">
        <text class="form-label">学生姓名 <text class="required">*</text></text>
        <input 
          class="form-input" 
          placeholder="请输入学生姓名"
          value="{{studentName}}"
          bindinput="onNameInput"
        />
      </view>

      <view class="form-item">
        <text class="form-label">学号 <text class="required">*</text></text>
        <input 
          class="form-input" 
          placeholder="请输入学号"
          value="{{studentId}}"
          bindinput="onStudentIdInput"
        />
      </view>

      <view class="form-item">
        <text class="form-label">联系电话</text>
        <input 
          class="form-input" 
          placeholder="请输入联系电话"
          value="{{phone}}"
          type="number"
          bindinput="onPhoneInput"
        />
      </view>
    </view>

    <!-- 房间信息 -->
    <view class="form-section">
      <view class="section-title">房间信息</view>
      
      <view class="form-item">
        <text class="form-label">选择楼栋 <text class="required">*</text></text>
        <picker bindchange="onBuildingChange" value="{{buildings.indexOf(selectedBuilding)}}" range="{{buildings}}">
          <view class="picker {{selectedBuilding ? 'selected' : 'placeholder'}}">
            {{selectedBuilding || '请选择楼栋'}}
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">选择房间 <text class="required">*</text></text>
        <picker bindchange="onRoomChange" value="{{rooms.indexOf(selectedRoom)}}" range="{{rooms}}" disabled="{{!selectedBuilding}}">
          <view class="picker {{selectedRoom ? 'selected' : 'placeholder'}} {{!selectedBuilding ? 'disabled' : ''}}">
            {{selectedRoom || (selectedBuilding ? '请选择房间' : '请先选择楼栋')}}
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button 
      class="submit-btn {{loading ? 'loading' : ''}}" 
      bindtap="submitCheckIn"
      disabled="{{loading}}"
    >
      <text wx:if="{{!loading}}">确认办理入住</text>
      <text wx:else>处理中...</text>
    </button>
  </view>

</view>
