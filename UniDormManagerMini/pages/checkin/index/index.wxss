/* pages/checkin/index/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding: var(--space-3);
  padding-bottom: calc(var(--space-5) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
}

/* 页面标题 */
.page-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-4);
  padding: var(--space-3) 0;
}

.header-icon {
  font-size: 64rpx;
  margin-right: var(--space-3);
}

.header-content {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  box-shadow: var(--shadow-md);
  margin-bottom: var(--space-4);
}

.form-section {
  margin-bottom: var(--space-4);
}

.form-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-2);
  border-bottom: 1rpx solid var(--gray-100);
}

.form-item {
  margin-bottom: var(--space-3);
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.required {
  color: var(--danger);
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--space-3);
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.form-input:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

/* Picker 样式 */
.picker {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--space-3);
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.picker.placeholder {
  color: var(--text-tertiary);
}

.picker.selected {
  color: var(--text-primary);
  background: rgba(102, 126, 234, 0.05);
  border-color: rgba(102, 126, 234, 0.3);
}

.picker.disabled {
  background: var(--gray-100);
  color: var(--text-tertiary);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

/* 提交按钮 */
.submit-section {
  padding: var(--space-2) 0;
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(16, 185, 129, 0.3);
  transition: all 0.2s ease;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 24rpx rgba(16, 185, 129, 0.4);
}

.submit-btn.loading {
  opacity: 0.7;
}
