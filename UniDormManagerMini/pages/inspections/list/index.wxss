/* pages/inspections/list/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding: var(--space-3);
  padding-bottom: calc(var(--space-5) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
}

/* 页面标题 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-4);
  padding: var(--space-3) 0;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.header-date {
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--gray-100);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-3);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: var(--space-3);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-3);
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-3);
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 查寝列表 */
.inspection-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.inspection-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  box-shadow: var(--shadow-md);
  transition: all 0.2s ease;
}

.inspection-card:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-lg);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-3);
  border-bottom: 1rpx solid var(--gray-100);
}

.room-info {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.building-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  background: var(--gray-100);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
}

.room-number {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.status-tag {
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
}

.status-normal {
  background: var(--success-light);
  color: var(--success);
}

.status-abnormal {
  background: var(--danger-light);
  color: var(--danger);
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.info-row {
  display: flex;
  align-items: flex-start;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: var(--text-primary);
  flex: 1;
}

/* 浮动操作按钮 */
.fab {
  position: fixed;
  right: var(--space-4);
  bottom: calc(var(--space-4) + constant(safe-area-inset-bottom));
  bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-xl);
  z-index: 100;
  transition: transform 0.2s ease;
}

.fab:active {
  transform: scale(0.9);
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
}
