<!--pages/inspections/list/index.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-title">查寝记录</text>
    <text class="header-date">{{currentDate}}</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && inspectionList.length === 0}}">
    <text class="empty-icon">📝</text>
    <text class="empty-title">暂无查寝记录</text>
    <text class="empty-desc">点击右下角按钮开始查寝</text>
  </view>

  <!-- 查寝列表 -->
  <view class="inspection-list" wx:if="{{!loading && inspectionList.length > 0}}">
    <view class="inspection-card" 
          wx:for="{{inspectionList}}" 
          wx:key="id"
          bindtap="viewDetail"
          data-id="{{item.id}}">
      <view class="card-header">
        <view class="room-info">
          <text class="building-name">{{item.buildingName}}</text>
          <text class="room-number">{{item.roomNumber}}</text>
        </view>
        <view class="status-tag {{item.status === 'normal' ? 'status-normal' : 'status-abnormal'}}">
          {{item.status === 'normal' ? '正常' : '异常'}}
        </view>
      </view>
      
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">查寝时间：</text>
          <text class="info-value">{{item.checkTime}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">检查人：</text>
          <text class="info-value">{{item.inspector}}</text>
        </view>
        <view class="info-row" wx:if="{{item.notes}}">
          <text class="info-label">备注：</text>
          <text class="info-value">{{item.notes}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 浮动操作按钮 -->
  <view class="fab" bindtap="addInspection">
    <text class="fab-icon">+</text>
  </view>

</view>
