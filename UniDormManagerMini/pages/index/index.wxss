/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding: var(--space-3);
  padding-bottom: calc(var(--space-5) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
}

/* ----- 欢迎区域 - 毛玻璃效果 ----- */
.welcome-section {
  position: relative;
  padding: 48rpx 32rpx;
  background: var(--primary-gradient);
  border-radius: var(--radius-xl);
  margin-bottom: var(--space-4);
  box-shadow: var(--shadow-xl);
  overflow: hidden;
}

.welcome-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.welcome-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.welcome-text {
  display: block;
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: var(--space-2);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.date-text {
  display: block;
  position: relative;
  z-index: 1;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

/* ----- 统计卡片区域 ----- */
.stats-section {
  margin-bottom: var(--space-4);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-3);
}

.stat-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  box-shadow: var(--shadow-md);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: var(--primary-gradient);
  opacity: 0;
  transition: opacity 0.2s ease;
}

.stat-card:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-lg);
}

.stat-card:active::before {
  opacity: 1;
}

.stat-card.primary::before { background: var(--primary-gradient); }
.stat-card.success::before { background: linear-gradient(90deg, #10b981, #34d399); }
.stat-card.warning::before { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
.stat-card.danger::before { background: linear-gradient(90deg, #ef4444, #f87171); }
.stat-card.info::before { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
.stat-card.secondary::before { background: linear-gradient(90deg, #8b5cf6, #a78bfa); }

.stat-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-2);
}

.stat-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: var(--space-2);
}

.stat-card.primary .stat-icon { background: var(--info-light); }
.stat-card.success .stat-icon { background: var(--success-light); }
.stat-card.warning .stat-icon { background: var(--warning-light); }
.stat-card.danger .stat-icon { background: var(--danger-light); }
.stat-card.info .stat-icon { background: var(--info-light); }
.stat-card.secondary .stat-icon { background: rgba(139, 92, 246, 0.1); }

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
  margin-bottom: var(--space-1);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ----- 快捷操作区域 ----- */
.quick-actions {
  background: #fff;
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  margin-bottom: var(--space-4);
  box-shadow: var(--shadow-md);
}

.action-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-4);
  display: flex;
  align-items: center;
}

.action-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--primary-gradient);
  border-radius: var(--radius-full);
  margin-right: var(--space-2);
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-3);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2);
  border-radius: var(--radius-lg);
  transition: all 0.2s ease;
}

.action-item:active {
  background: var(--gray-100);
  transform: scale(0.95);
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-lg);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 48rpx;
  margin-bottom: var(--space-2);
  transition: transform 0.2s ease;
  position: relative;
  overflow: hidden;
}

.action-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.15;
}

.action-item:active .action-icon {
  transform: scale(1.1);
}

.room-icon::before { background: linear-gradient(135deg, #3b82f6, #60a5fa); }
.repair-icon::before { background: linear-gradient(135deg, #f59e0b, #fbbf24); }
.notice-icon::before { background: linear-gradient(135deg, #10b981, #34d399); }
.profile-icon::before { background: linear-gradient(135deg, #8b5cf6, #a78bfa); }

.action-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ----- 提示信息区域 ----- */
.tips-section {
  margin-bottom: var(--space-3);
}

.tip-card {
  background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
  border-left: 4rpx solid var(--warning);
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease;
}

.tip-card:active {
  transform: translateX(8rpx);
}

.tip-icon {
  font-size: 40rpx;
  margin-right: var(--space-2);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.tip-text {
  font-size: 28rpx;
  color: var(--gray-700);
  font-weight: 500;
  flex: 1;
}

/* ----- 加载状态 ----- */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-3);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: var(--space-3);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ----- 响应式调整 ----- */
@media screen and (min-width: 768px) {
  .stats-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .action-grid {
    grid-template-columns: repeat(6, 1fr);
  }
}
