/* pages/index/index.wxss */

/* ==================== 全局变量 ==================== */
page {
  --primary-color: #4f46e5;
  --primary-gradient: linear-gradient(135deg, #4f46e5, #7c3aed);
  --success-color: #10b981;
  --success-gradient: linear-gradient(135deg, #10b981, #34d399);
  --warning-color: #f59e0b;
  --warning-gradient: linear-gradient(135deg, #f59e0b, #fbbf24);
  --danger-color: #ef4444;
  --danger-gradient: linear-gradient(135deg, #ef4444, #f87171);
  --info-color: #3b82f6;
  --info-gradient: linear-gradient(135deg, #3b82f6, #60a5fa);
  
  --text-primary: #1e293b;
  --text-secondary: #64748b;
  --text-tertiary: #94a3b8;
  
  --gray-50: #f8fafc;
  --gray-100: #f1f5f9;
  --gray-200: #e2e8f0;
  
  --success-light: rgba(16, 185, 129, 0.1);
  --warning-light: rgba(245, 158, 11, 0.1);
  --danger-light: rgba(239, 68, 68, 0.1);
  --info-light: rgba(59, 130, 246, 0.1);
  
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-full: 9999rpx;
  
  --shadow-sm: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1);
  --shadow-xl: 0 20rpx 25rpx -5rpx rgba(0, 0, 0, 0.1);
  --shadow-glow: 0 0 20rpx rgba(102, 126, 234, 0.4);
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--gray-50) 0%, #fff 100%);
  padding: var(--space-3);
  padding-bottom: calc(140rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ==================== 通用头部 ==================== */
.header-section {
  position: relative;
  padding: 48rpx 36rpx;
  border-radius: var(--radius-xl);
  margin-bottom: var(--space-4);
  box-shadow: var(--shadow-lg);
  overflow: hidden;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.header-section::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.student-header {
  background: var(--primary-gradient);
}

.dorm_manager-header {
  background: linear-gradient(135deg, #0891b2 0%, #06b6d4 50%, #22d3ee 100%);
}

.maintenance-header {
  background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 50%, #3d7ab5 100%);
}

.admin-header {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #9333ea 100%);
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.welcome-info {
  flex: 1;
}

.welcome-text {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: var(--space-2);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.date-text {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.role-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border-radius: var(--radius-lg);
  padding: var(--space-2) var(--space-3);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.role-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.role-name {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 600;
}

/* ==================== 轮播图 ==================== */
.banner-section {
  margin-bottom: var(--space-4);
}

.banner-swiper {
  height: 200rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}

.banner-item {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-4);
  transition: all 0.3s ease;
}

.banner-item:active {
  transform: scale(0.98);
}

.banner-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.banner-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: var(--space-1);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  text-align: center;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
}

/* ==================== 加载状态 ==================== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-3);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: var(--space-3);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ==================== 区块标题 ==================== */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-3);
}

.title-icon {
  font-size: 32rpx;
  margin-right: var(--space-2);
}

.title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
}

.title-more {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* ==================== 统计卡片 ==================== */
.stats-section {
  margin-bottom: var(--space-4);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-3);
}

.stat-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  box-shadow: var(--shadow-md);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.stat-card:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-lg);
}

.stat-card:active::before {
  opacity: 1;
}

.stat-card.primary::before { background: var(--primary-gradient); }
.stat-card.success::before { background: var(--success-gradient); }
.stat-card.warning::before { background: var(--warning-gradient); }
.stat-card.danger::before { background: var(--danger-gradient); }
.stat-card.info::before { background: var(--info-gradient); }

.stat-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-2);
}

.stat-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.stat-card.primary .stat-icon { background: var(--info-light); }
.stat-card.success .stat-icon { background: var(--success-light); }
.stat-card.warning .stat-icon { background: var(--warning-light); }
.stat-card.danger .stat-icon { background: var(--danger-light); }
.stat-card.info .stat-icon { background: var(--info-light); }

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
  margin-bottom: var(--space-1);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ==================== 快捷功能入口 ==================== */
.quick-actions {
  background: #fff;
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  margin-bottom: var(--space-4);
  box-shadow: var(--shadow-md);
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-3);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-2);
  border-radius: var(--radius-lg);
  transition: all 0.2s ease;
}

.action-item:active {
  background: var(--gray-100);
  transform: scale(0.95);
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-lg);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 48rpx;
  margin-bottom: var(--space-2);
  transition: transform 0.2s ease;
  position: relative;
  overflow: hidden;
}

.action-item:active .action-icon {
  transform: scale(1.1);
}

.action-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.15;
}

.room-icon::before { background: var(--primary-gradient); }
.repair-icon::before { background: var(--warning-gradient); }
.notice-icon::before { background: var(--success-gradient); }
.profile-icon::before { background: linear-gradient(135deg, #8b5cf6, #a78bfa); }
.student-icon::before { background: var(--primary-gradient); }
.pending-icon::before { background: var(--danger-gradient); }
.progress-icon::before { background: var(--warning-gradient); }
.completed-icon::before { background: var(--success-gradient); }
.stats-icon::before { background: var(--info-gradient); }
.overview-icon::before { background: var(--primary-gradient); }
.user-icon::before { background: linear-gradient(135deg, #8b5cf6, #a78bfa); }
.settings-icon::before { background: var(--text-secondary); }

.action-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ==================== 最新动态 ==================== */
.activity-section {
  background: #fff;
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  margin-bottom: var(--space-4);
  box-shadow: var(--shadow-md);
}

/* 通知列表 */
.notice-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.notice-item {
  display: flex;
  align-items: center;
  padding: var(--space-3);
  background: var(--gray-50);
  border-radius: var(--radius-lg);
  transition: all 0.2s ease;
}

.notice-item:active {
  background: var(--gray-100);
  transform: translateX(8rpx);
}

.notice-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--primary-color);
  margin-right: var(--space-2);
}

.notice-content {
  flex: 1;
  min-width: 0;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.notice-time {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.notice-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
}

/* 报修列表 */
.repair-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.repair-item {
  display: flex;
  align-items: center;
  padding: var(--space-3);
  background: var(--gray-50);
  border-radius: var(--radius-lg);
  transition: all 0.2s ease;
}

.repair-item:active {
  background: var(--gray-100);
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-md);
}

.repair-priority {
  width: 40rpx;
  display: flex;
  justify-content: center;
  margin-right: var(--space-2);
}

.priority-icon {
  font-size: 32rpx;
}

.repair-info {
  flex: 1;
  min-width: 0;
}

.repair-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.repair-meta {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.repair-location {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.repair-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.repair-status {
  margin-left: var(--space-2);
}

.status-tag {
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  font-size: 20rpx;
  font-weight: 500;
}

.status-tag.Pending {
  background: var(--warning-light);
  color: var(--warning-color);
}

.status-tag.InProgress {
  background: var(--info-light);
  color: var(--info-color);
}

.status-tag.Completed {
  background: var(--success-light);
  color: var(--success-color);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx var(--space-3);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-2);
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* ==================== 响应式调整 ==================== */
@media screen and (min-width: 768px) {
  .stats-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .action-grid {
    grid-template-columns: repeat(6, 1fr);
  }
}
