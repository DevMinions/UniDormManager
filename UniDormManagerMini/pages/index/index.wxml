<!--pages/index/index.wxml-->
<view class="container">
  
  <!-- ========== 通用头部 ========== -->
  <view class="header-section {{viewType}}-header">
    <view class="header-content">
      <view class="welcome-info">
        <text class="welcome-text">{{welcomeText}}，{{userName}}</text>
        <text class="date-text">{{currentDate}}</text>
      </view>
      
      <view class="role-badge" wx:if="{{viewType !== 'student'}}">
        <text class="role-icon">{{viewType === 'admin' ? '🛡️' : viewType === 'dorm_manager' ? '📋' : '🔧'}}</text>
        <text class="role-name">{{userRoleName}}</text>
      </view>
    </view>
  </view>

  <!-- ========== 轮播图/公告 ========== -->
  <view class="banner-section" wx:if="{{banners.length > 0}}">
    <swiper class="banner-swiper" indicator-dots="true" autoplay="true" interval="5000" duration="500" circular="true">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <view class="banner-item" style="background: {{item.color}}" bindtap="onBannerTap" data-banner="{{item}}">
          <view class="banner-content">
            <text class="banner-title">{{item.title}}</text>
            <text class="banner-desc">{{item.content}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- ========== 加载状态 ========== -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:if="{{!loading}}">
    
    <!-- ========== 【学生视图】 ========== -->
    <block wx:if="{{viewType === 'student'}}">
      
      <!-- 统计卡片 -->
      <view class="stats-section">
        <view class="section-title">
          <text class="title-icon">📊</text>
          <text class="title-text">我的数据</text>
        </view>
        
        <view class="stats-grid">
          <view class="stat-card warning" bindtap="goToRepairs">
            <view class="stat-header">
              <view class="stat-icon">🔧</view>
            </view>
            <text class="stat-value">{{stats.myRepairs}}</text>
            <text class="stat-label">我的报修</text>
          </view>

          <view class="stat-card info" bindtap="goToNoticesStudent">
            <view class="stat-header">
              <view class="stat-icon">📢</view>
            </view>
            <text class="stat-value">{{stats.unreadNotices}}</text>
            <text class="stat-label">未读通知</text>
          </view>

          <view class="stat-card primary" bindtap="goToMyRoom">
            <view class="stat-header">
              <view class="stat-icon">🏠</view>
            </view>
            <text class="stat-value">{{stats.totalRooms > 0 ? '查看' : '-'}}</text>
            <text class="stat-label">我的房间</text>
          </view>

          <view class="stat-card success" bindtap="goToRooms">
            <view class="stat-header">
              <view class="stat-icon">✅</view>
            </view>
            <text class="stat-value">{{stats.freeRooms}}</text>
            <text class="stat-label">空闲房间</text>
          </view>
        </view>
      </view>

      <!-- 快捷功能入口 -->
      <view class="quick-actions">
        <view class="section-title">
          <text class="title-icon">⚡</text>
          <text class="title-text">快捷功能</text>
        </view>
        
        <view class="action-grid">
          <view class="action-item" bindtap="goToSubmitRepair">
            <view class="action-icon repair-icon">🔧</view>
            <text class="action-text">报修</text>
          </view>

          <view class="action-item" bindtap="goToMyRoom">
            <view class="action-icon room-icon">🏠</view>
            <text class="action-text">我的房间</text>
          </view>

          <view class="action-item" bindtap="goToNoticesStudent">
            <view class="action-icon notice-icon">📢</view>
            <text class="action-text">通知公告</text>
          </view>

          <view class="action-item" bindtap="goToProfile">
            <view class="action-icon profile-icon">👤</view>
            <text class="action-text">个人中心</text>
          </view>
        </view>
      </view>

      <!-- 最新动态 -->
      <view class="activity-section">
        <view class="section-title">
          <text class="title-icon">🔔</text>
          <text class="title-text">最新通知</text>
          <text class="title-more" bindtap="goToMoreNotices">查看更多 ›</text>
        </view>

        <view class="notice-list">
          <view class="notice-item" 
                wx:for="{{recentNotices}}" 
                wx:key="id"
                bindtap="goToNoticeDetail"
                data-id="{{item.id}}">
            <view class="notice-dot"></view>
            <view class="notice-content">
              <text class="notice-title">{{item.title}}</text>
              <text class="notice-time">{{formatTime(item.createdAt)}}</text>
            </view>
            <view class="notice-arrow">›</view>
          </view>
        </view>

        <view class="empty-state" wx:if="{{recentNotices.length === 0}}">
          <text class="empty-icon">📭</text>
          <text class="empty-text">暂无最新通知</text>
        </view>
      </view>
    </block>

    <!-- ========== 【宿管员视图】 ========== -->
    <block wx:if="{{viewType === 'dorm_manager'}}">
      
      <!-- 统计卡片 -->
      <view class="stats-section">
        <view class="section-title">
          <text class="title-icon">📊</text>
          <text class="title-text">数据概览</text>
        </view>
        
        <view class="stats-grid">
          <view class="stat-card primary" bindtap="goToStudents">
            <view class="stat-header">
              <view class="stat-icon">🎓</view>
            </view>
            <text class="stat-value">{{stats.totalStudents}}</text>
            <text class="stat-label">学生总数</text>
          </view>

          <view class="stat-card success" bindtap="goToRooms">
            <view class="stat-header">
              <view class="stat-icon">🏠</view>
            </view>
            <text class="stat-value">{{stats.freeRooms}}</text>
            <text class="stat-label">空闲房间</text>
          </view>

          <view class="stat-card warning" bindtap="goToHandleRepairs">
            <view class="stat-header">
              <view class="stat-icon">🔧</view>
            </view>
            <text class="stat-value">{{stats.pendingRepairs}}</text>
            <text class="stat-label">待处理报修</text>
          </view>

          <view class="stat-card info" bindtap="goToRooms">
            <view class="stat-header">
              <view class="stat-icon">📊</view>
            </view>
            <text class="stat-value">{{stats.occupiedRooms}}</text>
            <text class="stat-label">已入住</text>
          </view>
        </view>
      </view>

      <!-- 快捷功能入口 -->
      <view class="quick-actions">
        <view class="section-title">
          <text class="title-icon">⚡</text>
          <text class="title-text">管理功能</text>
        </view>
        
        <view class="action-grid manager-grid">
          <view class="action-item" bindtap="goToStudents">
            <view class="action-icon student-icon">👥</view>
            <text class="action-text">学生管理</text>
          </view>

          <view class="action-item" bindtap="goToRooms">
            <view class="action-icon room-icon">🏢</view>
            <text class="action-text">房间管理</text>
          </view>

          <view class="action-item" bindtap="goToHandleRepairs">
            <view class="action-icon repair-icon">🔧</view>
            <text class="action-text">报修处理</text>
          </view>

          <view class="action-item" bindtap="goToPublishNotice">
            <view class="action-icon notice-icon">📢</view>
            <text class="action-text">通知发布</text>
          </view>
        </view>
      </view>

      <!-- 最新动态 -->
      <view class="activity-section">
        <view class="section-title">
          <text class="title-icon">🔔</text>
          <text class="title-text">最新报修</text>
          <text class="title-more" bindtap="goToMoreRepairs">查看更多 ›</text>
        </view>

        <view class="repair-list">
          <view class="repair-item" 
                wx:for="{{recentRepairs}}" 
                wx:key="id"
                bindtap="goToTicketDetail"
                data-id="{{item.id}}">
            
<view class="repair-priority {{item.priority === 'High' ? 'urgent' : item.priority === 'Medium' ? 'normal' : 'low'}}">
              <text class="priority-icon">{{item.priority === 'High' ? '🔴' : item.priority === 'Medium' ? '🟡' : '🟢'}}</text>
            </view>
            
            <view class="repair-info">
              <text class="repair-title">{{item.title || item.description}}</text>
              <view class="repair-meta">
                <text class="repair-location">📍 {{item.location || item.roomNumber}}</text>
                <text class="repair-time">{{formatTime(item.createdAt)}}</text>
              </view>
            </view>
            
            <view class="repair-status">
              <text class="status-tag {{item.status}}">{{item.status === 'Pending' ? '待处理' : item.status === 'In Progress' ? '处理中' : '已完成'}}</text>
            </view>
          </view>
        </view>

        <view class="empty-state" wx:if="{{recentRepairs.length === 0}}">
          <text class="empty-icon">✅</text>
          <text class="empty-text">暂无待处理报修</text>
        </view>
      </view>
    </block>

    <!-- ========== 【维修工视图】 ========== -->
    <block wx:if="{{viewType === 'maintenance'}}">
      
      <!-- 统计卡片 -->
      <view class="stats-section">
        <view class="section-title">
          <text class="title-icon">📊</text>
          <text class="title-text">工单统计</text>
        </view>
        
        <view class="stats-grid">
          <view class="stat-card danger" bindtap="goToPendingTickets">
            <view class="stat-header">
              <view class="stat-icon">⏳</view>
            </view>
            <text class="stat-value">{{stats.pendingCount}}</text>
            <text class="stat-label">待处理</text>
          </view>

          <view class="stat-card warning" bindtap="goToInProgressTickets">
            <view class="stat-header">
              <view class="stat-icon">🔧</view>
            </view>
            <text class="stat-value">{{stats.inProgressCount}}</text>
            <text class="stat-label">处理中</text>
          </view>

          <view class="stat-card success" bindtap="goToCompletedTickets">
            <view class="stat-header">
              <view class="stat-icon">✅</view>
            </view>
            <text class="stat-value">{{stats.completedToday}}</text>
            <text class="stat-label">今日完成</text>
          </view>

          <view class="stat-card info" bindtap="goToStatistics">
            <view class="stat-header">
              <view class="stat-icon">📈</view>
            </view>
            <text class="stat-value">{{stats.weekTotal}}</text>
            <text class="stat-label">本周统计</text>
          </view>
        </view>
      </view>

      <!-- 快捷功能入口 -->
      <view class="quick-actions">
        <view class="section-title">
          <text class="title-icon">⚡</text>
          <text class="title-text">快捷操作</text>
        </view>
        
        <view class="action-grid maintenance-grid">
          <view class="action-item" bindtap="goToPendingTickets">
            <view class="action-icon pending-icon">📋</view>
            <text class="action-text">待处理</text>
          </view>

          <view class="action-item" bindtap="goToInProgressTickets">
            <view class="action-icon progress-icon">🔨</view>
            <text class="action-text">处理中</text>
          </view>

          <view class="action-item" bindtap="goToCompletedTickets">
            <view class="action-icon completed-icon">✨</view>
            <text class="action-text">已完成</text>
          </view>

          <view class="action-item" bindtap="goToStatistics">
            <view class="action-icon stats-icon">📊</view>
            <text class="action-text">统计</text>
          </view>
        </view>
      </view>

      <!-- 紧急工单提醒 -->
      <view class="urgent-banner" wx:if="{{maintenanceStats.urgentCount > 0}}" bindtap="filterByPriority" data-priority="High">
        <view class="urgent-icon">🚨</view>
        <view class="urgent-content">
          <text class="urgent-title">紧急工单提醒</text>
          <text class="urgent-desc">当前有 {{maintenanceStats.urgentCount}} 个紧急工单需要优先处理</text>
        </view>
        <view class="urgent-arrow">›</view>
      </view>

      <!-- 最新待处理工单 -->
      <view class="activity-section">
        <view class="section-title">
          <text class="title-icon">🎯</text>
          <text class="title-text">最新待处理</text>
          <text class="title-more" bindtap="goToPendingTickets">查看全部 ›</text>
        </view>

        <view class="repair-list">
          <view class="repair-item" 
                wx:for="{{recentRepairs}}" 
                wx:key="id"
                bindtap="goToTicketDetail"
                data-id="{{item.id}}">
            <view class="repair-priority {{item.priority === 'High' ? 'urgent' : item.priority === 'Medium' ? 'normal' : 'low'}}">
              <text class="priority-icon">{{item.priority === 'High' ? '🔴' : item.priority === 'Medium' ? '🟡' : '🟢'}}</text>
            </view>
            
            <view class="repair-info">
              <text class="repair-title">{{item.title || item.description}}</text>
              <view class="repair-meta">
                <text class="repair-location">📍 {{item.location || item.roomNumber}}</text>
                <text class="repair-time">{{formatTime(item.createdAt)}}</text>
              </view>
            </view>
            
            <view class="repair-action" catchtap="quickAccept" data-id="{{item.id}}">
              <text class="action-btn">接单</text>
            </view>
          </view>
        </view>

        <view class="empty-state" wx:if="{{recentRepairs.length === 0}}">
          <text class="empty-icon">🎉</text>
          <text class="empty-text">暂无待处理工单</text>
        </view>
      </view>
    </block>

    <!-- ========== 【管理员视图】 ========== -->
    <block wx:if="{{viewType === 'admin'}}">
      
      <!-- 统计卡片 -->
      <view class="stats-section">
        <view class="section-title">
          <text class="title-icon">📊</text>
          <text class="title-text">数据概览</text>
        </view>
        
        <view class="stats-grid admin-stats-grid">
          <view class="stat-card primary" bindtap="goToUsers">
            <view class="stat-header">
              <view class="stat-icon">👥</view>
            </view>
            <text class="stat-value">{{stats.totalUsers}}</text>
            <text class="stat-label">总用户数</text>
          </view>

          <view class="stat-card success" bindtap="goToRooms">
            <view class="stat-header">
              <view class="stat-icon">🏠</view>
            </view>
            <text class="stat-value">{{stats.totalRooms}}</text>
            <text class="stat-label">总房间数</text>
          </view>

          <view class="stat-card warning" bindtap="goToRepairs">
            <view class="stat-header">
              <view class="stat-icon">🔧</view>
            </view>
            <text class="stat-value">{{stats.todayRepairs}}</text>
            <text class="stat-label">今日报修</text>
          </view>

          <view class="stat-card info" bindtap="goToOverview">
            <view class="stat-header">
              <view class="stat-icon">📅</view>
            </view>
            <text class="stat-value">{{stats.systemDays}}</text>
            <text class="stat-label">运行天数</text>
          </view>
        </view>
      </view>

      <!-- 管理功能快捷入口 -->
      <view class="quick-actions">
        <view class="section-title">
          <text class="title-icon">🎯</text>
          <text class="title-text">管理功能</text>
        </view>
        
        <view class="action-grid admin-grid">
          <view class="action-item" bindtap="goToOverview">
            <view class="action-icon overview-icon">📊</view>
            <text class="action-text">数据概览</text>
          </view>

          <view class="action-item" bindtap="goToUsers">
            <view class="action-icon user-icon">👤</view>
            <text class="action-text">用户管理</text>
          </view>

          <view class="action-item" bindtap="goToSettings">
            <view class="action-icon settings-icon">⚙️</view>
            <text class="action-text">系统设置</text>
          </view>

          <view class="action-item" bindtap="goToRooms">
            <view class="action-icon room-icon">🏢</view>
            <text class="action-text">房间管理</text>
          </view>

          <view class="action-item" bindtap="goToStudents">
            <view class="action-icon student-icon">🎓</view>
            <text class="action-text">学生管理</text>
          </view>

          <view class="action-item" bindtap="goToRepairs">
            <view class="action-icon repair-icon">🔧</view>
            <text class="action-text">报修管理</text>
          </view>
        </view>
      </view>

      <!-- 数据趋势图表 -->
      <view class="charts-section">
        <view class="section-title">
          <text class="title-icon">📈</text>
          <text class="title-text">数据趋势</text>
        </view>

        <!-- 各楼栋入住率 -->
        <view class="chart-card">
          <view class="chart-header">
            <text class="chart-title">各楼栋入住率</text>
            <text class="chart-subtitle">实时数据</text>
          </view>
          
          <view class="chart-content">
            <view class="building-occupancy">
              <view class="building-item" wx:for="{{overviewData.buildingOccupancy}}" wx:key="name">
                <view class="building-info">
                  <text class="building-name">{{item.name}}</text>
                  <text class="building-rate">{{item.rate}}%</text>
                </view>
                <view class="progress-bar">
                  <view class="progress-fill {{item.rate >= 90 ? 'high' : item.rate >= 70 ? 'medium' : 'low'}}" 
                        style="width: {{item.rate}}%"></view>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 本周报修趋势 -->
        <view class="chart-card">
          <view class="chart-header">
            <text class="chart-title">本周报修趋势</text>
            <text class="chart-subtitle">最近7天</text>
          </view>
          
          <view class="chart-content">
            <view class="repair-trend">
              <view class="trend-item" wx:for="{{overviewData.weeklyRepairTrend}}" wx:key="day">
                <view class="trend-bar-container">
                  <view class="trend-bar" style="height: {{item.count * 10}}rpx"></view>
                </view>
                <text class="trend-day">{{item.day}}</text>
                <text class="trend-count">{{item.count}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 紧急待办 -->
      <view class="todos-section" wx:if="{{hasUrgentTodos}}">
        <view class="section-title">
          <text class="title-icon">⏰</text>
          <text class="title-text">紧急待办</text>
          <view class="todo-count" wx:if="{{urgentTodos.length > 0}}">
            <text class="count-badge">{{urgentTodos.length}}</text>
          </view>
        </view>
        
        <view class="todo-list">
          <view class="todo-item {{item.urgent ? 'urgent' : ''}}" 
                wx:for="{{urgentTodos}}" 
                wx:key="id"
                bindtap="onTodoClick"
                data-action="{{item.action}}">
            <view class="todo-icon">{{item.icon}}</view>
            <view class="todo-content">
              <view class="todo-title-row">
                <text class="todo-title">{{item.title}}</text>
                <view class="urgent-tag" wx:if="{{item.urgent}}">紧急</view>
              </view>
              <text class="todo-desc">{{item.desc}}</text>
            </view>
            <view class="todo-arrow">›</view>
          </view>
        </view>
      </view>
    </block>

  </block>
</view>
