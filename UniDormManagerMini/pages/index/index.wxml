<!--pages/index/index.wxml-->
<view class="container">
  
  <!-- ========== 欢迎区域 ========== -->
  <view class="welcome-section {{viewType === 'admin' ? 'admin-welcome' : ''}} {{viewType === 'maintenance' ? 'maintenance-welcome' : ''}}">
    <view class="welcome-content">
      <view class="welcome-main">
        <text class="welcome-text">{{welcomeTitle}}</text>
        <text class="date-text">{{currentDate}}</text>
      </view>
      
      <!-- 用户身份标识 -->
      <view class="role-badge" wx:if="{{viewType !== 'student'}}">
        <text class="role-icon">{{viewType === 'admin' ? '🛡️' : '🔧'}}</text>
        <text class="role-name">{{userRoleName}}</text>
      </view>
    </view>
  </view>

  <!-- ========== 加载状态 ========== -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:if="{{!loading}}">
    
    <!-- ========== 【维修工视图】工作台 ========== -->
    <block wx:if="{{viewType === 'maintenance'}}">
      
      <!-- 工单统计概览 -->
      <view class="stats-section maintenance-stats">
        <view class="stats-grid">
          <view class="stat-card danger" bindtap="goToPendingTickets">
            <view class="stat-header">
              <view class="stat-icon">⏳</view>
            </view>
            <text class="stat-value">{{maintenanceStats.pendingCount}}</text>
            <text class="stat-label">待处理</text>
          </view>

          <view class="stat-card warning" bindtap="goToInProgressTickets">
            <view class="stat-header">
              <view class="stat-icon">🔧</view>
            </view>
            <text class="stat-value">{{maintenanceStats.inProgressCount}}</text>
            <text class="stat-label">处理中</text>
          </view>

          <view class="stat-card success" bindtap="goToCompletedTickets">
            <view class="stat-header">
              <view class="stat-icon">✅</view>
            </view>
            <text class="stat-value">{{maintenanceStats.completedToday}}</text>
            <text class="stat-label">今日完成</text>
          </view>

          <view class="stat-card info" bindtap="goToStatistics">
            <view class="stat-header">
              <view class="stat-icon">📊</view>
            </view>
            <text class="stat-value">{{maintenanceStats.newToday}}</text>
            <text class="stat-label">今日新增</text>
          </view>
        </view>
      </view>

      <!-- 紧急工单提醒 -->
      <view class="urgent-banner" wx:if="{{maintenanceStats.urgentCount > 0}}" bindtap="filterByPriority" data-priority="High">
        <view class="urgent-icon">🚨</view>
        <view class="urgent-content">
          <text class="urgent-title">紧急工单提醒</text>
          <text class="urgent-desc">当前有 {{maintenanceStats.urgentCount}} 个紧急工单需要优先处理</text>
        </view>
        <view class="urgent-arrow">›</view>
      </view>

      <!-- 快捷操作 -->
      <view class="quick-actions maintenance-actions">
        <view class="section-title">
          <text class="title-icon">⚡</text>
          <text class="title-text">快捷操作</text>
        </view>
        
        <view class="action-grid">
          <view class="action-item" bindtap="goToPendingTickets">
            <view class="action-icon pending-icon">📋</view>
            <text class="action-text">待处理</text>
          </view>

          <view class="action-item" bindtap="goToInProgressTickets">
            <view class="action-icon progress-icon">🔨</view>
            <text class="action-text">处理中</text>
          </view>

          <view class="action-item" bindtap="goToCompletedTickets">
            <view class="action-icon completed-icon">✨</view>
            <text class="action-text">已完成</text>
          </view>

          <view class="action-item" bindtap="goToStatistics">
            <view class="action-icon stats-icon">📈</view>
            <text class="action-text">统计</text>
          </view>
        </view>
      </view>

      <!-- 优先级筛选快捷入口 -->
      <view class="priority-filter-section">
        <view class="section-title">
          <text class="title-icon">🔖</text>
          <text class="title-text">按优先级筛选</text>
        </view>
        
        <view class="priority-filter-grid">
          <view class="priority-filter-item urgent-filter" bindtap="filterByPriority" data-priority="High">
            <view class="priority-dot red"></view>
            <text class="priority-label">紧急</text>
            <text class="priority-count" wx:if="{{maintenanceStats.urgentCount > 0}}">{{maintenanceStats.urgentCount}}</text>
          </view>
          
          <view class="priority-filter-item medium-filter" bindtap="filterByPriority" data-priority="Medium">
            <view class="priority-dot yellow"></view>
            <text class="priority-label">中等</text>
          </view>
          
          <view class="priority-filter-item low-filter" bindtap="filterByPriority" data-priority="Low">
            <view class="priority-dot green"></view>
            <text class="priority-label">普通</text>
          </view>
        </view>
      </view>

      <!-- 最新待处理工单 -->
      <view class="tickets-section" wx:if="{{recentTickets.length > 0}}">
        <view class="section-title">
          <text class="title-icon">🎯</text>
          <text class="title-text">最新待处理工单</text>
          <text class="title-more" bindtap="goToPendingTickets">查看全部 ›</text>
        </view>

        <view class="ticket-list">
          <view class="ticket-item" 
                wx:for="{{recentTickets}}" 
                wx:key="id"
                bindtap="goToTicketDetail"
                data-id="{{item.id}}">
            
            <view class="ticket-priority {{item.priority === 'High' ? 'urgent' : item.priority === 'Medium' ? 'normal' : 'low'}}">
              <text class="priority-icon">{{item.priority === 'High' ? '🔴' : item.priority === 'Medium' ? '🟡' : '🟢'}}</text>
            </view>
            
            <view class="ticket-info">
              <view class="ticket-title-row">
                <text class="ticket-title">{{item.title || item.description}}</text>
              </view>
              <view class="ticket-meta">
                <text class="ticket-location">📍 {{item.location || item.roomNumber}}</text>
                <text class="ticket-time">{{formatTime(item.createdAt || item.date)}}</text>
              </view>
            </view>
            
            <view class="ticket-action" catchtap="quickAccept" data-id="{{item.id}}">
              <text class="action-btn">接单</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- ========== 【管理员视图】管理控制台 ========== -->
    <block wx:if="{{viewType === 'admin'}}">
      
      <!-- 全局统计卡片 -->
      <view class="stats-section">
        <view class="section-title">
          <text class="title-icon">📊</text>
          <text class="title-text">数据概览</text>
        </view>
        
        <view class="stats-grid">
          <view class="stat-card primary" bindtap="goToRooms">
            <view class="stat-header">
              <view class="stat-icon">🏠</view>
            </view>
            <text class="stat-value">{{stats.totalRooms}}</text>
            <text class="stat-label">房间总数</text>
          </view>

          <view class="stat-card success" bindtap="goToRooms">
            <view class="stat-header">
              <view class="stat-icon">✅</view>
            </view>
            <text class="stat-value">{{stats.freeRooms}}</text>
            <text class="stat-label">空闲房间</text>
          </view>

          <view class="stat-card warning" bindtap="goToRooms">
            <view class="stat-header">
              <view class="stat-icon">👥</view>
            </view>
            <text class="stat-value">{{stats.occupiedRooms}}</text>
            <text class="stat-label">已入住</text>
          </view>

          <view class="stat-card danger" bindtap="goToRepairs">
            <view class="stat-header">
              <view class="stat-icon">🔧</view>
            </view>
            <text class="stat-value">{{stats.pendingRepairs}}</text>
            <text class="stat-label">待处理报修</text>
          </view>

          <view class="stat-card info" bindtap="goToStudents">
            <view class="stat-header">
              <view class="stat-icon">🎓</view>
            </view>
            <text class="stat-value">{{stats.totalStudents}}</text>
            <text class="stat-label">学生总数</text>
          </view>

          <view class="stat-card secondary" bindtap="goToRooms">
            <view class="stat-header">
              <view class="stat-icon">🏢</view>
            </view>
            <text class="stat-value">{{stats.totalBuildings}}</text>
            <text class="stat-label">楼栋总数</text>
          </view>
        </view>
      </view>

      <!-- 管理功能快捷入口 -->
      <view class="admin-actions">
        <view class="section-title">
          <text class="title-icon">🎯</text>
          <text class="title-text">管理功能</text>
        </view>
        
        <view class="action-grid">
          <view class="action-item" 
                wx:if="{{permissions.canManageStudents}}"
                bindtap="goToStudents"
                data-permission="students">
            <view class="action-icon student-icon">👥</view>
            <text class="action-text">学生管理</text>
          </view>

          <view class="action-item" 
                wx:if="{{permissions.canManageRooms}}"
                bindtap="goToRooms"
                data-permission="rooms">
            <view class="action-icon room-icon">🏢</view>
            <text class="action-text">房间管理</text>
          </view>

          <view class="action-item" 
                wx:if="{{permissions.canManageNotices}}"
                bindtap="goToNotices"
                data-permission="notices">
            <view class="action-icon notice-icon">📢</view>
            <text class="action-text">公告管理</text>
          </view>

          <view class="action-item" 
                wx:if="{{permissions.canManageRepairs}}"
                bindtap="goToRepairs"
                data-permission="repairs">
            <view class="action-icon repair-icon">🔧</view>
            <text class="action-text">报修管理</text>
          </view>

          <view class="action-item" 
                wx:if="{{permissions.canManageUsers}}"
                bindtap="goToUsers"
                data-permission="users">
            <view class="action-icon user-icon">👤</view>
            <text class="action-text">用户管理</text>
          </view>

          <view class="action-item" 
                wx:if="{{permissions.canSystemSettings}}"
                bindtap="goToSettings"
                data-permission="settings">
            <view class="action-icon settings-icon">⚙️</view>
            <text class="action-text">系统设置</text>
          </view>
        </view>
      </view>

      <!-- 数据概览图表区域 -->
      <view class="charts-section">
        <view class="section-title">
          <text class="title-icon">📈</text>
          <text class="title-text">数据趋势</text>
        </view>

        <!-- 各楼栋入住率 -->
        <view class="chart-card">
          <view class="chart-header">
            <text class="chart-title">各楼栋入住率对比</text>
            <text class="chart-subtitle">实时数据</text>
          </view>
          
          <view class="chart-content">
            <view class="building-occupancy">
              <view class="building-item" wx:for="{{overviewData.buildingOccupancy}}" wx:key="name">
                <view class="building-info">
                  <text class="building-name">{{item.name}}</text>
                  <text class="building-rate">{{item.rate}}%</text>
                </view>
                <view class="progress-bar">
                  <view class="progress-fill {{item.rate >= 90 ? 'high' : item.rate >= 70 ? 'medium' : 'low'}}" 
                        style="width: {{item.rate}}%"></view>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- 本周报修趋势 -->
        <view class="chart-card">
          <view class="chart-header">
            <text class="chart-title">本周报修趋势</text>
            <text class="chart-subtitle">最近7天</text>
          </view>
          
          <view class="chart-content">
            <view class="repair-trend">
              <view class="trend-item" wx:for="{{overviewData.weeklyRepairTrend}}" wx:key="day">
                <view class="trend-bar-container">
                  <view class="trend-bar" style="height: {{item.count * 10}}rpx"></view>
                </view>
                <text class="trend-day">{{item.day}}</text>
                <text class="trend-count">{{item.count}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 紧急待办 -->
      <view class="todos-section" wx:if="{{hasUrgentTodos}}">
        <view class="section-title">
          <text class="title-icon">⏰</text>
          <text class="title-text">紧急待办</text>
          <view class="todo-count" wx:if="{{urgentTodos.length > 0}}">
            <text class="count-badge">{{urgentTodos.length}}</text>
          </view>
        </view>
        
        <view class="todo-list">
          <view class="todo-item {{item.urgent ? 'urgent' : ''}}" 
                wx:for="{{urgentTodos}}" 
                wx:key="id"
                bindtap="onTodoClick"
                data-action="{{item.action}}">
            <view class="todo-icon">{{item.icon}}</view>
            <view class="todo-content">
              <view class="todo-title-row">
                <text class="todo-title">{{item.title}}</text>
                <view class="urgent-tag" wx:if="{{item.urgent}}">紧急</view>
              </view>
              <text class="todo-desc">{{item.desc}}</text>
            </view>
            <view class="todo-arrow">›</view>
          </view>
        </view>
      </view>
    </block>

    <!-- ========== 【学生视图】普通用户首页 ========== -->
    <block wx:if="{{viewType === 'student'}}">
      
      <!-- 统计卡片 -->
      <view class="stats-section">
        <view class="stats-grid">
          <view class="stat-card primary" bindtap="goToRooms">
            <view class="stat-header">
              <view class="stat-icon">🏠</view>
            </view>
            <text class="stat-value">{{stats.totalRooms}}</text>
            <text class="stat-label">房间总数</text>
          </view>

          <view class="stat-card success" bindtap="goToRooms">
            <view class="stat-header">
              <view class="stat-icon">✅</view>
            </view>
            <text class="stat-value">{{stats.freeRooms}}</text>
            <text class="stat-label">空闲房间</text>
          </view>

          <view class="stat-card warning" bindtap="goToRooms">
            <view class="stat-header">
              <view class="stat-icon">👥</view>
            </view>
            <text class="stat-value">{{stats.occupiedRooms}}</text>
            <text class="stat-label">已入住</text>
          </view>

          <view class="stat-card danger" bindtap="goToRepairs">
            <view class="stat-header">
              <view class="stat-icon">🔧</view>
            </view>
            <text class="stat-value">{{stats.pendingRepairs}}</text>
            <text class="stat-label">待处理报修</text>
          </view>
        </view>
      </view>

      <!-- 快捷操作 -->
      <view class="quick-actions">
        <view class="section-title">
          <text class="title-icon">⚡</text>
          <text class="title-text">快捷操作</text>
        </view>
        
        <view class="action-grid">
          <view class="action-item" bindtap="goToRooms">
            <view class="action-icon room-icon">🏠</view>
            <text class="action-text">房间查询</text>
          </view>

          <view class="action-item" bindtap="goToRepairs">
            <view class="action-icon repair-icon">🔧</view>
            <text class="action-text">报修申请</text>
          </view>

          <view class="action-item" bindtap="goToNotices">
            <view class="action-icon notice-icon">📢</view>
            <text class="action-text">公告通知</text>
          </view>

          <view class="action-item" bindtap="goToProfile">
            <view class="action-icon profile-icon">👤</view>
            <text class="action-text">个人中心</text>
          </view>
        </view>
      </view>

      <!-- 提示信息 -->
      <view class="tips-section" wx:if="{{stats.pendingRepairs > 0}}">
        <view class="tip-card" bindtap="goToRepairs">
          <text class="tip-icon">💡</text>
          <text class="tip-text">您有 {{stats.pendingRepairs}} 个进行中的报修，点击查看进度</text>
        </view>
      </view>
    </block>

  </block>
</view>
