/* pages/notices/list/index.wxss */
/* 使用设计系统 CSS 变量 */

.container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: var(--space-3);
  box-sizing: border-box;
}

/* 筛选栏 */
.filter-section {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-2) 0;
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
}

.filter-scroll {
  white-space: nowrap;
  padding: 0 var(--space-2);
}

.filter-item {
  display: inline-block;
  padding: var(--space-1) var(--space-3);
  margin: 0 var(--space-1);
  border-radius: var(--radius-full);
  font-size: 26rpx;
  color: var(--text-secondary);
  background-color: var(--gray-100);
  transition: all 0.3s ease;
}

.filter-item.active {
  background: var(--primary-gradient);
  color: var(--text-inverse);
  box-shadow: var(--shadow-md);
}

/* 公告列表 */
.notice-list {
  padding-bottom: var(--space-3);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--space-3);
  text-align: center;
}

.empty-state-icon {
  font-size: 120rpx;
  margin-bottom: var(--space-3);
  opacity: 0.4;
}

.empty-state-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
}

.empty-state-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 公告卡片 */
.notice-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  position: relative;
}

.notice-card:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-lg);
}

.notice-card.is-read {
  opacity: 0.85;
}

.notice-card.is-pinned {
  border-left: 6rpx solid var(--warning);
}

/* 置顶标识 */
.pinned-badge {
  position: absolute;
  top: -4rpx;
  right: 24rpx;
  background: var(--warning);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 0 0 var(--radius-sm) var(--radius-sm);
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 4rpx;
  box-shadow: 0 4rpx 8rpx rgba(245, 158, 11, 0.3);
}

.pinned-icon {
  font-size: 20rpx;
}

/* 头部信息 */
.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-2);
}

.notice-meta-left {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

/* 分类标签 */
.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
}

.category-tag.category-urgent {
  background: var(--danger-light);
  color: var(--danger);
}

.category-tag.category-maintenance {
  background: var(--warning-light);
  color: var(--warning);
}

.category-tag.category-activity {
  background: var(--success-light);
  color: var(--success);
}

.category-tag.category-general {
  background: var(--info-light);
  color: var(--info);
}

/* 未读标识 */
.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--danger);
  border-radius: 50%;
  flex-shrink: 0;
}

/* 发布时间 */
.notice-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.date-icon {
  font-size: 22rpx;
}

/* 标题 */
.notice-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
  line-height: 1.5;
}

.notice-card.is-read .notice-title {
  color: var(--text-secondary);
  font-weight: 500;
}

/* 摘要 */
.notice-preview {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: var(--space-2);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.notice-card.is-read .notice-preview {
  color: var(--text-tertiary);
}

/* 底部 */
.notice-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--space-2);
  border-top: 1rpx solid var(--gray-100);
}

.view-detail {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.read-status {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.read-status.is-unread {
  color: var(--primary-color);
  font-weight: 500;
}

.status-icon {
  font-size: 24rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx var(--space-3);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: var(--space-2);
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: var(--space-3) 0;
  color: var(--text-tertiary);
  font-size: 26rpx;
}

.load-more-icon {
  display: inline-block;
  margin-right: 8rpx;
}

.no-more {
  color: var(--gray-400);
}
