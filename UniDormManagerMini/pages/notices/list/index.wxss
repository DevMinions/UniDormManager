/* pages/notices/list/index.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.filter-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.filter-scroll {
  white-space: nowrap;
}

.filter-item {
  display: inline-block;
  padding: 15rpx 30rpx;
  margin: 0 10rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f5f5f5;
  transition: all 0.3s;
}

.filter-item.active {
  background-color: #1890ff;
  color: #fff;
}

.notice-list {
  padding-bottom: 20rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
  color: #999;
}

.notice-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.notice-category {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.notice-category.category-urgent {
  background-color: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.notice-category.category-maintenance {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.notice-category.category-activity {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.notice-category.category-general {
  background-color: rgba(24, 144, 255, 0.1);
  color: #1890ff;
}

.notice-date {
  font-size: 22rpx;
  color: #999;
}

.notice-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.notice-preview {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 15rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.notice-footer {
  padding-top: 15rpx;
  border-top: 1rpx solid #f5f5f5;
  text-align: right;
}

.view-detail {
  font-size: 26rpx;
  color: #1890ff;
}
