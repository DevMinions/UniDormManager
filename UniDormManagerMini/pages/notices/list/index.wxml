<!--pages/notices/list/index.wxml-->
<view class="container">
  <!-- 分类筛选 -->
  <view class="filter-section">
    <scroll-view class="filter-scroll" scroll-x="true">
      <view
        class="filter-item {{selectedCategory === 'all' ? 'active' : ''}}"
        data-category="all"
        bindtap="filterCategory"
      >
        全部
      </view>
      <view
        class="filter-item {{selectedCategory === 'urgent' ? 'active' : ''}}"
        data-category="urgent"
        bindtap="filterCategory"
      >
        紧急通知
      </view>
      <view
        class="filter-item {{selectedCategory === 'maintenance' ? 'active' : ''}}"
        data-category="maintenance"
        bindtap="filterCategory"
      >
        维修通知
      </view>
      <view
        class="filter-item {{selectedCategory === 'activity' ? 'active' : ''}}"
        data-category="activity"
        bindtap="filterCategory"
      >
        活动通知
      </view>
      <view
        class="filter-item {{selectedCategory === 'general' ? 'active' : ''}}"
        data-category="general"
        bindtap="filterCategory"
      >
        一般通知
      </view>
    </scroll-view>
  </view>

  <!-- 公告列表 -->
  <view class="notice-list">
    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <view class="empty-state" wx:elif="{{notices.length === 0}}">
      <text>暂无公告</text>
    </view>

    <view
      class="notice-card"
      wx:for="{{notices}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToDetail"
    >
      <view class="notice-header">
        <view class="notice-category category-{{item.category}}">
          {{item.categoryText || item.category}}
        </view>
        <view class="notice-date">{{item.publishedAt || item.published_at}}</view>
      </view>

      <view class="notice-title">{{item.title}}</view>

      <view class="notice-preview">
        {{item.description || item.content}}
      </view>

      <view class="notice-footer">
        <text class="view-detail">查看详情 ›</text>
      </view>
    </view>
  </view>
</view>
