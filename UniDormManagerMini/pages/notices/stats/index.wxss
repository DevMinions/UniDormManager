/* pages/notices/stats/index.wxss */
/* 使用设计系统 CSS 变量 */

.container {
  min-height: 100vh;
  background-color: var(--bg-primary);
}

/* 导航栏 */
.navbar {
  background: var(--primary-gradient);
  padding: var(--space-2) var(--space-3);
  padding-top: calc(var(--space-2) + env(safe-area-inset-top));
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 100;
}

.navbar-left {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: rgba(255, 255, 255, 0.15);
  transition: background 0.2s ease;
}

.back-btn:active {
  background: rgba(255, 255, 255, 0.25);
}

.back-icon {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx var(--space-3);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: var(--space-2);
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 滚动区 */
.stats-scroll {
  height: 100vh;
  padding: var(--space-3);
}

/* 公告信息 */
.notice-info {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-sm);
}

.notice-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: var(--space-1);
  display: block;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 统计卡片 */
.stats-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.stat-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease;
}

.stat-card:active {
  transform: scale(0.98);
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.stat-card.stat-primary .stat-value {
  color: var(--primary-color);
}

.stat-card.stat-success .stat-value {
  color: var(--success);
}

.stat-card.stat-warning .stat-value {
  color: var(--warning);
}

.stat-card.stat-info .stat-value {
  color: var(--info);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 阅读进度 */
.progress-section {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-sm);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-3);
}

.progress-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.progress-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.progress-bar {
  height: 16rpx;
  background: var(--gray-100);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-bottom: var(--space-2);
}

.progress-fill {
  height: 100%;
  background: var(--primary-gradient);
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}

.progress-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* 阅读记录区块 */
.records-section {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  box-shadow: var(--shadow-sm);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-2);
  border-bottom: 1rpx solid var(--gray-100);
}

.section-icon {
  font-size: 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx var(--space-3);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: var(--space-2);
  opacity: 0.4;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 记录列表 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.record-item {
  display: flex;
  align-items: center;
  padding: var(--space-2);
  border-radius: var(--radius-md);
  transition: background 0.2s ease;
}

.record-item:active {
  background: var(--gray-50);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  margin-right: var(--space-2);
  background: var(--gray-100);
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}

.user-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.read-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.record-sub {
  display: flex;
  align-items: center;
  gap: var(--space-1);
}

.room-info {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: var(--space-3) 0;
  color: var(--text-tertiary);
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.load-more-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.no-more {
  color: var(--gray-400);
}

/* 底部留白 */
.bottom-spacer {
  height: var(--space-4);
}
