<!--pages/notices/stats/index.wxml-->
<view class="container">
  <!-- 导航栏 -->
  <view class="navbar">
    <view class="navbar-left">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">←</text>
      </view>
      <text class="navbar-title">阅读统计</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading && !notice}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 统计内容 -->
  <view class="content-wrapper" wx:if="{{notice}}">
    <!-- 公告信息 -->
    <view class="notice-info-card">
      <view class="notice-info-header">
        <text class="info-icon">📢</text>
        <text class="info-title">公告信息</text>
      </view>
      <view class="notice-info-content">
        <view class="notice-title">{{notice.title}}</view>
        <view class="notice-meta">
          <text class="meta-tag">{{notice.categoryText || notice.category}}</text>
          <text class="meta-text">{{notice.publishedAt || notice.published_at || notice.createdAt || notice.created_at}}</text>
        </view>
      </view>
    </view>

    <!-- 统计概览 -->
    <view class="stats-overview">
      <view class="stat-card stat-total">
        <view class="stat-icon">👥</view>
        <view class="stat-info">
          <view class="stat-value">{{stats.total}}</view>
          <view class="stat-label">总人数</view>
        </view>
      </view>
      <view class="stat-card stat-read">
        <view class="stat-icon">✓</view>
        <view class="stat-info">
          <view class="stat-value">{{stats.read}}</view>
          <view class="stat-label">已读</view>
        </view>
      </view>
      <view class="stat-card stat-unread">
        <view class="stat-icon">●</view>
        <view class="stat-info">
          <view class="stat-value">{{stats.unread}}</view>
          <view class="stat-label">未读</view>
        </view>
      </view>
      <view class="stat-card stat-rate">
        <view class="stat-icon">📊</view>
        <view class="stat-info">
          <view class="stat-value">{{stats.readRate}}%</view>
          <view class="stat-label">阅读率</view>
        </view>
      </view>
    </view>

    <!-- 阅读率进度条 -->
    <view class="rate-progress-card">
      <view class="rate-progress-header">
        <text class="rate-progress-title">阅读率进度</text>
        <text class="rate-progress-value">{{stats.readRate}}%</text>
      </view>
      <view class="rate-progress-bar">
        <view 
          class="rate-progress-fill" 
          style="width: {{stats.readRate}}%"
        ></view>
      </view>
      <view class="rate-progress-footer">
        <text class="rate-progress-text">已读 {{stats.read}} / {{stats.total}} 人</text>
      </view>
    </view>

    <!-- 阅读记录列表 -->
    <view class="records-section">
      <view class="section-header">
        <text class="section-icon">📖</text>
        <text class="section-title">阅读记录</text>
        <text class="section-count">({{records.length}})</text>
      </view>
      
      <scroll-view 
        class="records-list" 
        scroll-y="true" 
        bindscrolltolower="loadMoreRecords"
        enhanced="true"
        show-scrollbar="false"
      >
        <!-- 加载中 -->
        <view class="loading-container" wx:if="{{loading && records.length === 0}}">
          <view class="loading-spinner"></view>
          <text class="loading-text">加载中...</text>
        </view>

        <!-- 空状态 -->
        <view class="empty-state" wx:elif="{{!loading && records.length === 0}}">
          <text class="empty-state-icon">📭</text>
          <text class="empty-state-title">暂无阅读记录</text>
        </view>

        <!-- 记录列表 -->
        <block wx:if="{{records.length > 0}}">
          <view class="record-item" wx:for="{{records}}" wx:key="id">
            <view class="record-avatar">
              <image 
                class="avatar-image" 
                src="{{item.userAvatar || item.user_avatar || item.avatar || '/images/default-avatar.png'}}"
                mode="aspectFill"
              />
            </view>
            <view class="record-info">
              <view class="record-header">
                <text class="record-name">{{item.userName || item.user_name || item.name || item.nickname || '未知用户'}}</text>
                <text class="record-time">{{formatTime(item.readTime)}}</text>
              </view>
              <view class="record-room" wx:if="{{item.roomInfo || item.room_info || item.room}}">
                <text class="room-icon">🏠</text>
                <text class="room-text">{{item.roomInfo || item.room_info || item.room}}</text>
              </view>
            </view>
            <view class="record-status read">
              <text class="status-icon">✓</text>
            </view>
          </view>

          <!-- 加载更多 -->
          <view class="load-more" wx:if="{{hasMore && !loadingMore}}">
            <text>上拉加载更多</text>
          </view>
          <view class="load-more" wx:if="{{loadingMore}}">
            <view class="load-more-spinner"></view>
            <text>加载中...</text>
          </view>
          <view class="load-more no-more" wx:if="{{!hasMore && records.length > 0}}">
            <text>—— 已经到底了 ——</text>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>
</view>
