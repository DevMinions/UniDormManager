/* pages/notices/publish/index.wxss */
/* 使用设计系统 CSS 变量 */

.container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx var(--space-3);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: var(--space-2);
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 表单滚动区 */
.form-scroll {
  height: 100vh;
  padding: var(--space-3);
}

/* 表单区块 */
.form-section {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-3);
  display: flex;
  align-items: center;
}

.required {
  color: var(--danger);
  margin-right: 4rpx;
}

/* 标题输入 */
.title-input {
  width: 100%;
  font-size: 32rpx;
  color: var(--text-primary);
  line-height: 1.5;
  border: none;
  outline: none;
}

.title-input::placeholder {
  color: var(--text-tertiary);
}

/* 分类选择 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-2);
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-3);
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  position: relative;
  transition: all 0.2s ease;
}

.category-item:active {
  transform: scale(0.98);
}

.category-item.active {
  background: var(--primary-light);
  border-color: var(--primary-color);
  color: var(--primary-color);
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: var(--space-1);
}

.category-label {
  font-size: 26rpx;
  font-weight: 500;
}

.check-icon {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 24rpx;
  color: var(--primary-color);
}

/* 内容输入 */
.content-input {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
  border: none;
  outline: none;
}

.content-input::placeholder {
  color: var(--text-tertiary);
}

/* 字符计数 */
.char-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-2);
}

/* 快捷标签 */
.quick-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-2);
  margin-top: var(--space-3);
  padding-top: var(--space-3);
  border-top: 1rpx solid var(--gray-100);
}

.tag-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.tag-item {
  padding: 8rpx 20rpx;
  background: var(--primary-light);
  color: var(--primary-color);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
}

/* 接收对象列表 */
.target-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.target-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-3);
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.target-item:active {
  transform: scale(0.99);
}

.target-item.active {
  background: var(--primary-light);
  border-color: var(--primary-color);
}

.target-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.target-label {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.target-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.target-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--primary-color);
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-circle {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 开关行 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-2) 0;
}

.switch-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 附件列表 */
.attachment-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  margin-bottom: var(--space-2);
}

.attachment-item {
  display: flex;
  align-items: center;
  padding: var(--space-2) var(--space-3);
  background: var(--gray-50);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--gray-100);
}

.attachment-icon {
  font-size: 36rpx;
  margin-right: var(--space-2);
}

.attachment-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.attachment-name {
  font-size: 26rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attachment-size {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.delete-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--danger-light);
  color: var(--danger);
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: bold;
}

/* 上传按钮 */
.upload-btn {
  width: 100%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: var(--gray-50);
  border: 2rpx dashed var(--gray-300);
  border-radius: var(--radius-md);
  color: var(--text-secondary);
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.upload-btn::after {
  border: none;
}

.upload-btn:active {
  background: var(--gray-100);
}

.upload-btn[disabled] {
  opacity: 0.5;
}

.upload-icon {
  font-size: 32rpx;
  font-weight: bold;
}

/* 底部留白 */
.bottom-spacer {
  height: var(--space-4);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-3) calc(var(--space-3) + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--gray-100);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.cancel-btn {
  flex: 0 0 auto;
  width: 140rpx;
  height: 80rpx;
  background: #fff;
  color: var(--text-secondary);
  border: 1rpx solid var(--gray-200);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-weight: 500;
}

.cancel-btn::after {
  border: none;
}

.draft-btn {
  flex: 0 0 auto;
  width: 140rpx;
  height: 80rpx;
  background: var(--info-light);
  color: var(--info);
  border: 1rpx solid var(--info);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  font-weight: 500;
}

.draft-btn::after {
  border: none;
}

.submit-btn {
  flex: 1;
  height: 80rpx;
  background: var(--primary-gradient);
  color: #fff;
  border: none;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}
