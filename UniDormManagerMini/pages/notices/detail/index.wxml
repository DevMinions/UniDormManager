<!--pages/notices/detail/index.wxml-->
<view class="container">
  <!-- 导航栏 -->
  <view class="navbar">
    <view class="navbar-left">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">←</text>
      </view>
      <text class="navbar-title">公告详情</text>
    </view>
    <view class="navbar-right">
      <view class="menu-btn" wx:if="{{isAdmin}}" bindtap="showAdminMenu">
        <text class="menu-icon">⋮</text>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:elif="{{error}}">
    <text class="error-icon">⚠️</text>
    <text class="error-title">{{errorMsg || '加载失败'}}</text>
    <button class="retry-btn" bindtap="loadNoticeDetail">重新加载</button>
  </view>

  <!-- 公告详情 -->
  <view class="content-wrapper" wx:elif="{{notice}}">
    <!-- 标题区域 -->
    <view class="header-section">
      <!-- 置顶标识 -->
      <view class="pinned-header" wx:if="{{notice.isPinned || notice.is_pinned}}">
        <text class="pinned-icon">📌</text>
        <text class="pinned-text">置顶公告</text>
      </view>

      <!-- 分类标签 -->
      <view class="category-badge category-{{notice.category}}">
        {{notice.categoryText || notice.category}}
      </view>

      <!-- 标题 -->
      <view class="notice-title">{{notice.title}}</view>

      <!-- 元信息 -->
      <view class="meta-info">
        <view class="meta-item">
          <text class="meta-icon">📅</text>
          <text>{{notice.formattedTime}}</text>
        </view>
        
        <view class="meta-divider"></view>
        
        <view class="meta-item" wx:if="{{notice.author || notice.publisher}}">
          <text class="meta-icon">👤</text>
          <text>{{notice.author || notice.publisher}}</text>
        </view>
        
        <view class="meta-divider"></view>
        
        <view class="read-status {{!notice.isRead && !notice.is_read ? 'is-unread' : ''}}">
          <text class="read-status-text">{{notice.isRead || notice.is_read ? '已读' : '未读'}}</text>
        </view>
      </view>
    </view>

    <!-- 公告内容 -->
    <view class="content-section">
      <view class="section-header">
        <text class="section-icon">📝</text>
        <text class="section-title">公告正文</text>
      </view>
      <view class="notice-content">
        <text wx:if="{{!notice.content}}">暂无正文内容</text>
        <rich-text wx:else nodes="{{notice.content}}"></rich-text>
      </view>
    </view>

    <!-- 附件 -->
    <view class="attachments-section" wx:if="{{notice.attachments && notice.attachments.length > 0}}">
      <view class="section-header">
        <text class="section-icon">📎</text>
        <text class="section-title">相关附件（{{notice.attachments.length}}个）</text>
      </view>
      <view class="attachment-list">
        <view 
          class="attachment-item" 
          wx:for="{{notice.attachments}}" 
          wx:key="id"
          data-url="{{item.url}}"
          data-name="{{item.name}}"
          bindtap="downloadAttachment"
        >
          <view class="attachment-icon-wrap">
            <text class="attachment-icon">📄</text>
          </view>
          <view class="attachment-info">
            <view class="attachment-name">{{item.name}}</view>
            <view class="attachment-size" wx:if="{{item.size}}">{{item.size}}</view>
          </view>
          <text class="attachment-action">下载</text>
        </view>
      </view>
    </view>

    <!-- 上一篇/下一篇导航 -->
    <view class="nav-section" wx:if="{{prevNotice || nextNotice}}">
      <view class="section-header">
        <text class="section-icon">📖</text>
        <text class="section-title">更多公告</text>
      </view>
      
      <view class="nav-item nav-prev {{!prevNotice ? 'disabled' : ''}}" bindtap="goToPrev">
        <view class="nav-label">
          <text class="nav-arrow">↑</text>
          <text>上一篇</text>
        </view>
        <view class="nav-title" wx:if="{{prevNotice}}">{{prevNotice.title}}</view>
        <view class="nav-title nav-empty" wx:else>没有了</view>
      </view>
      
      <view class="nav-divider"></view>
      
      <view class="nav-item nav-next {{!nextNotice ? 'disabled' : ''}}" bindtap="goToNext">
        <view class="nav-label">
          <text class="nav-arrow">↓</text>
          <text>下一篇</text>
        </view>
        <view class="nav-title" wx:if="{{nextNotice}}">{{nextNotice.title}}</view>
        <view class="nav-title nav-empty" wx:else>没有了</view>
      </view>
    </view>

    <!-- 提示信息 -->
    <view class="tips-section">
      <view class="tips-header">
        <text class="tips-icon">💡</text>
        <text class="tips-title">温馨提示</text>
      </view>
      <view class="tips-list">
        <view class="tips-item">
          <text class="tips-bullet">•</text>
          <text>本公告由宿舍管理系统发布</text>
        </view>
        <view class="tips-item">
          <text class="tips-bullet">•</text>
          <text>如有疑问请联系宿舍管理员</text>
        </view>
        <view class="tips-item">
          <text class="tips-bullet">•</text>
          <text>请及时查看并遵守公告内容</text>
        </view>
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="action-section">
      <button class="back-home-btn" bindtap="goBack">
        <text>返回</text>
      </button>
      <button class="share-btn" open-type="share">
        <text class="share-icon">📤</text>
        <text>分享给好友</text>
      </button>
    </view>
  </view>
</view>
