/* pages/notices/detail/index.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

.notice-detail {
  padding-bottom: 40rpx;
}

.header-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.category-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 20rpx;
}

.category-badge.category-urgent {
  background-color: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.category-badge.category-maintenance {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.category-badge.category-activity {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.category-badge.category-general {
  background-color: rgba(24, 144, 255, 0.1);
  color: #1890ff;
}

.notice-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.meta-info {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  flex-wrap: wrap;
}

.publish-time {
  margin-right: 20rpx;
}

.author {
  color: #666;
}

.content-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.notice-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

.attachments-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.attachment-list {
  margin-top: 10rpx;
}

.attachment-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.attachment-item:last-child {
  margin-bottom: 0;
}

.attachment-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.attachment-name {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.tips-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.tips-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}

.share-section {
  padding: 0 20rpx;
}

.share-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}
