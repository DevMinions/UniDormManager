/* pages/profile/index.wxss */

.container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: var(--space-3);
  padding-bottom: calc(var(--space-5) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
}

/* ----- 未登录提示 ----- */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: var(--space-4);
}

.prompt-icon {
  width: 200rpx;
  height: 200rpx;
  background: var(--gray-100);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
  margin-bottom: var(--space-4);
}

.prompt-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: var(--space-4);
}

.login-btn {
  width: 320rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  border: none;
  box-shadow: var(--shadow-lg);
}

/* ----- 用户信息卡片 ----- */
.user-card {
  background: #fff;
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
}

.avatar {
  position: relative;
  margin-right: var(--space-3);
}

.avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid var(--gray-100);
  box-shadow: var(--shadow-sm);
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 32rpx;
  height: 32rpx;
  background: var(--success);
  border-radius: 50%;
  border: 3rpx solid #fff;
}

.user-info {
  flex: 1;
}

.user-role-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: var(--space-2);
}

.user-role-tag.admin {
  background: var(--danger-light);
  color: var(--danger);
}

.user-role-tag.manager {
  background: var(--info-light);
  color: var(--info);
}

.user-role-tag.student {
  background: var(--success-light);
  color: var(--success);
}

.user-role-tag.maintenance {
  background: var(--warning-light);
  color: var(--warning);
}

.user-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.user-email {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.user-id {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ----- 角色权限提示卡片 ----- */
.admin-notice,
.student-notice,
.maintenance-notice {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-3);
  display: flex;
  align-items: flex-start;
  box-shadow: var(--shadow-sm);
}

.admin-notice {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
}

.student-notice {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
}

.maintenance-notice {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.notice-icon {
  font-size: 48rpx;
  margin-right: var(--space-2);
  margin-top: 4rpx;
}

.notice-text {
  flex: 1;
}

.notice-text text {
  display: block;
  font-size: 24rpx;
  color: var(--gray-700);
  line-height: 1.6;
}

.notice-text text:first-child {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-800);
  margin-bottom: 8rpx;
}

/* ----- 功能菜单 ----- */
.menu-section {
  background: #fff;
  border-radius: var(--radius-xl);
  padding: var(--space-3) 0;
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  padding: 0 var(--space-4) var(--space-3);
  margin-bottom: var(--space-2);
  border-bottom: 1rpx solid var(--gray-100);
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: var(--primary-gradient);
  border-radius: var(--radius-full);
  margin-right: var(--space-2);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--space-3) var(--space-4);
  transition: background 0.2s ease;
}

.menu-item:active {
  background: var(--gray-50);
}

.menu-item:not(:last-child) {
  border-bottom: 1rpx solid var(--gray-50);
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: var(--space-3);
}

.repair-icon {
  background: var(--warning-light);
}

.student-icon {
  background: var(--success-light);
}

.room-icon {
  background: var(--info-light);
}

.notice-icon {
  background: linear-gradient(135deg, #ddd6fe 0%, #c4b5fd 100%);
}

.menu-content {
  flex: 1;
}

.menu-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.menu-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.menu-arrow {
  font-size: 40rpx;
  color: var(--gray-400);
  font-weight: 300;
}

.admin-arrow {
  color: var(--primary-color);
}

/* ----- 退出登录 ----- */
.logout-section {
  margin-top: var(--space-4);
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: var(--danger);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.logout-btn:active {
  background: var(--danger-light);
  transform: scale(0.98);
}
