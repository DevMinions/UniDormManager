/* pages/rooms/detail/index.wxss */

.container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: var(--space-3);
  padding-bottom: 180rpx;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-3);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: var(--space-2);
  font-size: 28rpx;
  color: var(--text-secondary);
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-3);
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: var(--space-3);
}

.error-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-3);
}

.retry-btn {
  padding: 16rpx 48rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 600;
}

/* ===== 状态卡片 ===== */
.status-card {
  background: var(--primary-gradient);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-lg);
}

.status-card.status-available {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.status-card.status-occupied {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.status-card.status-maintenance {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.status-card.status-cleaning {
  background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
}

.status-card.status-reserved {
  background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
}

.status-icon {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 48rpx;
  margin-right: var(--space-3);
  backdrop-filter: blur(10rpx);
}

.status-info {
  flex: 1;
}

.status-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  display: block;
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

.status-badge {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  backdrop-filter: blur(10rpx);
}

/* ===== 标签栏 ===== */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-2);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-2);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
  position: relative;
}

.tab-item.active {
  background: var(--primary-light);
}

.tab-item.active .tab-icon,
.tab-item.active .tab-text {
  color: var(--primary-color);
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.tab-badge {
  position: absolute;
  top: 4rpx;
  right: 16rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: var(--danger);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* ===== 卡片通用样式 ===== */
.info-card,
.facilities-card,
.remark-card,
.students-card,
.repairs-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-2);
  border-bottom: 2rpx solid var(--gray-100);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}

.card-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--primary-gradient);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ===== 信息列表 ===== */
.info-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.info-item {
  display: flex;
  align-items: center;
  padding: var(--space-2) 0;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
}

.status-tag.status-available {
  background: var(--success-light);
  color: var(--success);
}

.status-tag.status-occupied {
  background: var(--primary-light);
  color: var(--primary-color);
}

.status-tag.status-maintenance {
  background: var(--warning-light);
  color: var(--warning);
}

.status-tag.status-cleaning {
  background: rgba(6, 182, 212, 0.1);
  color: #06b6d4;
}

.status-tag.status-reserved {
  background: rgba(139, 92, 246, 0.1);
  color: #8b5cf6;
}

/* ===== 编辑按钮 ===== */
.btn-edit {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: var(--gray-100);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--text-primary);
  border: none;
}

.btn-edit::after {
  border: none;
}

.btn-edit:active {
  background: var(--gray-200);
}

.btn-icon {
  margin-right: 8rpx;
}

/* ===== 设施网格 ===== */
.facilities-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-2);
}

.facility-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-2);
  background: var(--gray-50);
  border-radius: var(--radius-md);
}

.facility-icon {
  width: 32rpx;
  height: 32rpx;
  background: var(--success);
  color: #fff;
  border-radius: 50%;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.facility-name {
  font-size: 26rpx;
  color: var(--text-primary);
}

/* ===== 备注 ===== */
.remark-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
  white-space: pre-wrap;
}

/* ===== 学生列表 ===== */
.student-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.student-item {
  display: flex;
  align-items: center;
  padding: var(--space-3);
  background: var(--gray-50);
  border-radius: var(--radius-md);
  transition: background 0.2s ease;
}

.student-item:active {
  background: var(--gray-100);
}

.student-avatar {
  width: 88rpx;
  height: 88rpx;
  background: var(--primary-gradient);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-3);
  flex-shrink: 0;
}

.avatar-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.student-info {
  flex: 1;
  min-width: 0;
}

.student-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.student-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: var(--space-2);
}

.student-tag {
  background: var(--warning-light);
  color: var(--warning);
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
}

.student-detail {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.detail-item {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.student-actions {
  margin-left: var(--space-2);
}

.btn-call {
  width: 72rpx;
  height: 72rpx;
  background: var(--success-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
}

.btn-call::after {
  border: none;
}

.btn-call:active {
  transform: scale(0.95);
}

.call-icon {
  font-size: 32rpx;
}

/* ===== 报修列表 ===== */
.repair-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.repair-item {
  padding: var(--space-3);
  background: var(--gray-50);
  border-radius: var(--radius-md);
  transition: background 0.2s ease;
}

.repair-item:active {
  background: var(--gray-100);
}

.repair-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.repair-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: var(--space-2);
  word-break: break-all;
}

.repair-status {
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.repair-meta {
  display: flex;
  gap: var(--space-2);
  margin-bottom: 12rpx;
}

.repair-type {
  font-size: 24rpx;
  color: var(--primary-color);
  background: var(--primary-light);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
}

.repair-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.repair-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-3);
  background: #fff;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: var(--space-3);
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-4);
}

.empty-btn {
  padding: 20rpx 48rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.empty-btn::after {
  border: none;
}

/* ===== 底部操作栏 ===== */
.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: var(--space-3);
  padding-bottom: calc(var(--space-3) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-3) + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: var(--space-2);
  z-index: 100;
}

.bottom-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.bottom-btn::after {
  border: none;
}

.bottom-btn:active {
  transform: scale(0.98);
}

.btn-secondary {
  background: var(--gray-100);
  color: var(--text-primary);
}

.btn-primary {
  background: var(--primary-gradient);
  color: #fff;
  box-shadow: var(--shadow-md);
}
