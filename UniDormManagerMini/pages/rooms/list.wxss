/* pages/rooms/list.wxss */

.container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: var(--space-3);
  padding-bottom: calc(140rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ----- 搜索栏 ----- */
.search-section {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-sm);
}

.search-bar {
  display: flex;
  align-items: center;
  background: var(--bg-secondary);
  border-radius: var(--radius-full);
  padding: 0 var(--space-2);
  height: 80rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: var(--space-2);
  opacity: 0.6;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--text-primary);
  background: transparent;
}

.search-placeholder {
  color: var(--text-tertiary);
}

.search-btn {
  margin-left: var(--space-2);
  padding: 12rpx 28rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  transition: all 0.2s ease;
}

.search-btn:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-glow);
}

/* ----- 筛选区域 ----- */
.filter-section {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-2) 0;
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-sm);
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-2) var(--space-3);
  border-bottom: 1rpx solid var(--gray-100);
}

.filter-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.reset-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--text-tertiary);
  background: var(--gray-100);
  transition: all 0.2s ease;
}

.reset-btn.active {
  color: var(--primary-color);
  background: var(--info-light);
}

.reset-btn:active {
  transform: scale(0.95);
}

.reset-icon {
  margin-right: 6rpx;
  font-size: 22rpx;
}

.filter-scroll {
  white-space: nowrap;
  padding: var(--space-1) var(--space-2);
}

.floor-scroll {
  border-top: 1rpx solid var(--gray-100);
  border-bottom: 1rpx solid var(--gray-100);
}

.filter-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  margin: 0 var(--space-1);
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  background: var(--gray-100);
  transition: all 0.2s ease;
}

.filter-item:first-child {
  margin-left: var(--space-2);
}

.filter-item:last-child {
  margin-right: var(--space-2);
}

.filter-item.active {
  background: var(--primary-gradient);
  color: #fff;
  box-shadow: var(--shadow-md);
}

.filter-item:active {
  transform: scale(0.95);
}

/* ----- 房间列表 ----- */
.room-list {
  padding-bottom: var(--space-3);
}

/* ----- 房间卡片 ----- */
.room-card {
  display: flex;
  background: #fff;
  border-radius: var(--radius-xl);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  overflow: hidden;
  position: relative;
}

.room-card-hover {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-lg);
}

/* 左侧状态指示条 */
.status-indicator {
  width: 8rpx;
  min-height: 100%;
  flex-shrink: 0;
}

.room-card.status-free .status-indicator {
  background: var(--success);
}

.room-card.status-occupied .status-indicator {
  background: var(--warning);
}

.room-card.status-full .status-indicator {
  background: var(--danger);
}

.room-content {
  flex: 1;
  padding: var(--space-3);
}

/* 卡片头部 */
.room-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-3);
  border-bottom: 1rpx solid var(--gray-100);
}

.room-title-section {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.room-number {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

/* 房间类型标签 */
.room-type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 700;
}

.room-type-tag.type-male {
  background: var(--info-light);
  color: var(--info);
}

.room-type-tag.type-female {
  background: var(--danger-light);
  color: var(--danger);
}

.room-type-tag.type-mixed {
  background: var(--warning-light);
  color: var(--warning);
}

/* 房间状态标签 */
.room-status {
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.room-status.free {
  background: var(--success-light);
  color: var(--success);
}

.room-status.occupied {
  background: var(--warning-light);
  color: var(--warning);
}

.room-status.full {
  background: var(--danger-light);
  color: var(--danger);
}

/* 房间信息网格 */
.room-info {
  margin-bottom: var(--space-3);
}

.info-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.info-item {
  display: flex;
  align-items: center;
  flex: 1;
}

.info-icon {
  font-size: 32rpx;
  margin-right: var(--space-1);
  opacity: 0.8;
}

.info-content {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

/* 入住率进度条 */
.occupancy-section {
  background: var(--gray-50);
  border-radius: var(--radius-md);
  padding: var(--space-2);
}

.occupancy-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-2);
}

.occupancy-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.occupancy-value {
  font-size: 26rpx;
  font-weight: 700;
}

.occupancy-value.low {
  color: var(--success);
}

.occupancy-value.medium {
  color: var(--warning);
}

.occupancy-value.high {
  color: #f97316;
}

.occupancy-value.full {
  color: var(--danger);
}

.progress-bar {
  height: 12rpx;
  background: var(--gray-200);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.5s ease;
}

.progress-fill.low {
  background: linear-gradient(90deg, var(--success) 0%, #34d399 100%);
}

.progress-fill.medium {
  background: linear-gradient(90deg, var(--warning) 0%, #fbbf24 100%);
}

.progress-fill.high {
  background: linear-gradient(90deg, #f97316 0%, #fb923c 100%);
}

.progress-fill.full {
  background: linear-gradient(90deg, var(--danger) 0%, #f87171 100%);
}

/* 卡片底部 */
.room-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--space-3);
  border-top: 1rpx solid var(--gray-100);
}

.room-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.view-detail {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.view-detail .arrow {
  margin-left: 8rpx;
  font-size: 32rpx;
  line-height: 1;
}

/* ----- 加载状态 ----- */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-3);
}

.loading-container .loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: var(--space-3);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-container .loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ----- 空状态 ----- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--space-3);
  text-align: center;
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  background: var(--gray-100);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-4);
  font-size: 80rpx;
  opacity: 0.8;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  max-width: 400rpx;
  line-height: 1.5;
  margin-bottom: var(--space-3);
}

.empty-action {
  margin-top: var(--space-2);
}

.empty-btn {
  display: inline-block;
  padding: 16rpx 40rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-md);
}

.empty-btn:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-glow);
}

/* ----- 列表底部 ----- */
.list-footer {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: var(--space-4) 0;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
