/* pages/rooms/list.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.search-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.search-bar {
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 70rpx;
  background-color: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.search-btn {
  margin-left: 20rpx;
  padding: 15rpx 30rpx;
  background-color: #1890ff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 35rpx;
}

.room-list {
  padding-bottom: 20rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 100rpx 20rpx;
  color: #999;
}

.room-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.room-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.room-status {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.room-status.free {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.room-status.occupied {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.room-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 20rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.room-footer {
  padding-top: 15rpx;
  border-top: 1rpx solid #f5f5f5;
  text-align: right;
}

.view-detail {
  font-size: 26rpx;
  color: #1890ff;
}
