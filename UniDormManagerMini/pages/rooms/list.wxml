<!--pages/rooms/list.wxml-->
<view class="container container-safe">
  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索房间号"
        value="{{keyword}}"
        bindinput="handleSearch"
        bindconfirm="onSearch"
        placeholder-class="search-placeholder"
      />
      <view class="search-btn" bindtap="onSearch">搜索</view>
    </view>
  </view>

  <!-- 筛选区域 -->
  <view class="filter-section">
    <!-- 筛选头部 -->
    <view class="filter-header">
      <text class="filter-title">筛选条件</text>
      <view class="reset-btn {{keyword || selectedBuilding || selectedFloor || selectedStatus ? 'active' : ''}}" bindtap="resetFilters">
        <text class="reset-icon">↺</text>
        <text>重置</text>
      </view>
    </view>
    
    <!-- 楼栋筛选 -->
    <scroll-view class="filter-scroll" scroll-x enable-flex>
      <view
        class="filter-item {{selectedBuilding === item.id ? 'active' : ''}}"
        wx:for="{{buildings}}"
        wx:key="id"
        data-value="{{item.id}}"
        bindtap="selectBuilding"
      >
        {{item.name}}
      </view>
    </scroll-view>
    
    <!-- 楼层筛选 -->
    <scroll-view class="filter-scroll floor-scroll" scroll-x enable-flex>
      <view
        class="filter-item {{selectedFloor === item.id ? 'active' : ''}}"
        wx:for="{{floors}}"
        wx:key="id"
        data-value="{{item.id}}"
        bindtap="selectFloor"
      >
        {{item.name}}
      </view>
    </scroll-view>
    
    <!-- 状态筛选 -->
    <scroll-view class="filter-scroll status-scroll" scroll-x enable-flex>
      <view
        class="filter-item {{selectedStatus === item.id ? 'active' : ''}}"
        wx:for="{{statusList}}"
        wx:key="id"
        data-value="{{item.id}}"
        bindtap="selectStatus"
      >
        {{item.name}}
      </view>
    </scroll-view>
  </view>

  <!-- 房间列表 -->
  <view class="room-list">
    <!-- 加载状态 -->
    <view class="loading-container" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:elif="{{rooms.length === 0}}">
      <view class="empty-icon">🏠</view>
      <text class="empty-title">暂无房间数据</text>
      <text class="empty-desc" wx:if="{{keyword || selectedBuilding || selectedFloor || selectedStatus}}">暂无符合条件的房间，请调整筛选条件</text>
      <text class="empty-desc" wx:else>暂无房间数据，请联系管理员</text>
      <view class="empty-action" wx:if="{{keyword || selectedBuilding || selectedFloor || selectedStatus}}" bindtap="resetFilters">
        <text class="empty-btn">清除筛选</text>
      </view>
    </view>

    <!-- 房间卡片 -->
    <view
      class="room-card {{item.status === 'free' ? 'status-free' : item.status === 'full' ? 'status-full' : 'status-occupied'}}"
      wx:for="{{rooms}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToDetail"
      hover-class="room-card-hover"
      hover-stay-time="100"
    >
      <!-- 左侧状态指示条 -->
      <view class="status-indicator"></view>
      
      <view class="room-content">
        <!-- 卡片头部 -->
        <view class="room-header">
          <view class="room-title-section">
            <text class="room-number">{{item.roomNumber || item.room_number}}</text>
            <view class="room-type-tag {{item.typeClass}}">{{item.typeText}}</view>
          </view>
          <view class="room-status {{item.status}}">
            {{item.status === 'free' ? '空闲' : item.status === 'full' ? '已满' : '已入住'}}
          </view>
        </view>

        <!-- 房间信息 -->
        <view class="room-info">
          <view class="info-grid">
            <view class="info-item">
              <text class="info-icon">🏢</text>
              <view class="info-content">
                <text class="info-label">楼栋</text>
                <text class="info-value">{{item.buildingName || item.building_name || item.building || '-'}}</text>
              </view>
            </view>
            <view class="info-item">
              <text class="info-icon">📍</text>
              <view class="info-content">
                <text class="info-label">楼层</text>
                <text class="info-value">{{item.floor || '-'}}层</text>
              </view>
            </view>
            <view class="info-item">
              <text class="info-icon">👥</text>
              <view class="info-content">
                <text class="info-label">入住</text>
                <text class="info-value">{{item.occupied}}/{{item.capacity}}人</text>
              </view>
            </view>
          </view>
          
          <!-- 入住率进度条 -->
          <view class="occupancy-section">
            <view class="occupancy-header">
              <text class="occupancy-label">入住率</text>
              <text class="occupancy-value {{item.occupancyRate >= 100 ? 'full' : item.occupancyRate >= 75 ? 'high' : item.occupancyRate >= 50 ? 'medium' : 'low'}}">{{item.occupancyRate}}%</text>
            </view>
            <view class="progress-bar">
              <view 
                class="progress-fill {{item.occupancyRate >= 100 ? 'full' : item.occupancyRate >= 75 ? 'high' : item.occupancyRate >= 50 ? 'medium' : 'low'}}"
                style="width: {{item.occupancyRate}}%"
              ></view>
            </view>
          </view>
        </view>

        <!-- 卡片底部 -->
        <view class="room-footer">
          <text class="room-date" wx:if="{{item.updatedAt}}">更新于 {{item.updatedAt}}</text>
          <text class="room-date" wx:elif="{{item.updated_at}}">更新于 {{item.updated_at}}</text>
          <view class="view-detail">
            <text>查看详情</text>
            <text class="arrow">›</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 底部提示 -->
    <view class="list-footer" wx:if="{{rooms.length > 0 && !loading}}">
      <text class="footer-text">— 共 {{rooms.length}} 个房间 —</text>
    </view>
  </view>
</view>
