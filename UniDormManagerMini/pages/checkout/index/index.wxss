/* pages/checkout/index/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding: var(--space-3);
  padding-bottom: calc(var(--space-5) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
}

/* 页面标题 */
.page-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-4);
  padding: var(--space-3) 0;
}

.header-icon {
  font-size: 64rpx;
  margin-right: var(--space-3);
}

.header-content {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 搜索区域 */
.search-section {
  margin-bottom: var(--space-4);
}

.search-box {
  display: flex;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-2);
  box-shadow: var(--shadow-md);
}

.search-input {
  flex: 1;
  height: 80rpx;
  padding: 0 var(--space-3);
  font-size: 28rpx;
  color: var(--text-primary);
  background: var(--gray-50);
  border-radius: var(--radius-md);
  margin-right: var(--space-2);
}

.search-btn {
  width: 120rpx;
  height: 80rpx;
  background: var(--primary-gradient);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.search-btn text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.search-btn:active {
  transform: scale(0.95);
}

/* 信息卡片 */
.info-card {
  background: linear-gradient(135deg, #fff 0%, #fef2f2 100%);
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  box-shadow: var(--shadow-md);
  margin-bottom: var(--space-4);
  border-left: 8rpx solid var(--danger);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-3);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-2);
  padding: var(--space-2) 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.info-row:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.room-tag {
  background: var(--primary-gradient);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  box-shadow: var(--shadow-md);
  margin-bottom: var(--space-4);
}

.form-section {
  margin-bottom: var(--space-4);
}

.form-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-2);
  border-bottom: 1rpx solid var(--gray-100);
}

.form-item {
  margin-bottom: var(--space-3);
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.required {
  color: var(--danger);
}

.picker {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--space-3);
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: var(--space-3);
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

/* 检查项 */
.check-item {
  display: flex;
  align-items: center;
  padding: var(--space-3);
  background: var(--gray-50);
  border-radius: var(--radius-md);
  margin-bottom: var(--space-2);
  transition: all 0.2s ease;
}

.check-item:active {
  background: var(--gray-100);
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid var(--gray-300);
  margin-right: var(--space-3);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox.checked {
  background: var(--success);
  border-color: var(--success);
}

.checkbox text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.check-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 提交按钮 */
.submit-section {
  padding: var(--space-2) 0;
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #ef4444 0%, #f87171 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(239, 68, 68, 0.3);
  transition: all 0.2s ease;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 24rpx rgba(239, 68, 68, 0.4);
}

.submit-btn.loading {
  opacity: 0.7;
}

/* 空状态提示 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx var(--space-3);
  text-align: center;
}

.tip-icon {
  font-size: 64rpx;
  margin-bottom: var(--space-3);
  opacity: 0.6;
}

.tip-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}
