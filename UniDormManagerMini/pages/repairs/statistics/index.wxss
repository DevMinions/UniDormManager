/* pages/repairs/statistics/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding-bottom: calc(var(--space-5) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-5) + env(safe-area-inset-bottom));
}

/* ----- 页面头部 ----- */
.page-header {
  position: relative;
  padding: 60rpx 40rpx 100rpx;
  background: linear-gradient(135deg, #1e3a5f 0%, #2d5a87 50%, #3d7ab5 100%);
  overflow: hidden;
  margin-bottom: -60rpx;
}

.header-bg {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: var(--space-2);
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ----- 内容区域 ----- */
.content-wrapper {
  position: relative;
  z-index: 1;
  padding: 0 var(--space-3);
}

/* ----- 总览卡片 ----- */
.overview-section {
  margin-bottom: var(--space-4);
}

.overview-card {
  background: #fff;
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-lg);
}

.overview-item {
  flex: 1;
  text-align: center;
  padding: var(--space-2) 0;
}

.overview-divider {
  width: 1rpx;
  height: 80rpx;
  background: var(--gray-200);
}

.overview-number {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: var(--space-1);
  font-family: 'SF Mono', -apple-system, monospace;
}

.overview-number.total {
  color: var(--primary-color);
}

.overview-number.completed {
  color: #10b981;
}

.overview-number.pending {
  color: #f59e0b;
}

.overview-number.rate {
  color: #8b5cf6;
}

.overview-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ----- 区块样式 ----- */
.section {
  background: #fff;
  border-radius: var(--radius-xl);
  padding: var(--space-4);
  margin-bottom: var(--space-4);
  box-shadow: var(--shadow-md);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-3);
}

.header-left {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.section-line {
  width: 8rpx;
  height: 32rpx;
  background: var(--primary-gradient);
  border-radius: var(--radius-full);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ----- 今日数据 ----- */
.today-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-2);
}

.today-card {
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  text-align: center;
}

.today-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--space-2);
  box-shadow: var(--shadow-sm);
}

.today-icon {
  font-size: 40rpx;
}

.today-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-1);
}

.today-value.urgent {
  color: #ef4444;
}

.today-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ----- 优先级分布 ----- */
.priority-section {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.priority-item {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.priority-header {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  width: 140rpx;
  flex-shrink: 0;
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot-red {
  background: #ef4444;
}

.dot-yellow {
  background: #f59e0b;
}

.dot-green {
  background: #10b981;
}

.priority-name {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.priority-bar-bg {
  flex: 1;
  height: 16rpx;
  background: var(--gray-100);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.priority-bar {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.5s ease;
}

.priority-count {
  width: 60rpx;
  text-align: right;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex-shrink: 0;
}

/* ----- 维修类型 ----- */
.type-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: var(--space-2);
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: var(--space-2);
}

.type-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-2);
}

.type-icon {
  font-size: 40rpx;
}

.type-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.type-count {
  font-size: 32rpx;
  font-weight: 700;
}

/* ----- 趋势图 ----- */
.trend-section {
  padding: var(--space-2) 0;
}

.trend-chart {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 160rpx;
  padding: var(--space-3) 0;
  margin-bottom: var(--space-3);
  border-bottom: 1rpx solid var(--gray-100);
}

.trend-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
}

.trend-bars {
  display: flex;
  gap: 8rpx;
  align-items: flex-end;
  height: 100rpx;
}

.trend-bar {
  width: 16rpx;
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.5s ease;
}

.new-bar {
  background: linear-gradient(180deg, #3b82f6, #60a5fa);
}

.completed-bar {
  background: linear-gradient(180deg, #10b981, #34d399);
}

.trend-date {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.trend-legend {
  display: flex;
  justify-content: center;
  gap: var(--space-4);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: var(--space-1);
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.dot-new {
  background: #3b82f6;
}

.dot-completed {
  background: #10b981;
}

.legend-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ----- 个人绩效 ----- */
.performance-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-2);
}

.performance-card {
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  text-align: center;
}

.perf-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-1);
}

.perf-value.highlight {
  color: #f59e0b;
}

.perf-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ----- 加载状态 ----- */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx var(--space-3);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: var(--space-3);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ----- 响应式调整 ----- */
@media screen and (min-width: 768px) {
  .today-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .type-grid {
    grid-template-columns: repeat(5, 1fr);
  }
  
  .performance-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
