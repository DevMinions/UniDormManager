<!--pages/repairs/detail/index.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:elif="{{error}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{errorMessage}}</text>
    <button class="retry-btn" bindtap="loadRepairDetail">重新加载</button>
  </view>

  <!-- 报修详情 -->
  <view class="repair-detail" wx:else>
    <!-- 状态卡片 -->
    <view class="status-card status-{{repair.status}}">
      <view class="status-icon">🔧</view>
      <view class="status-info">
        <text class="status-text">{{statusMap[repair.status]}}</text>
        <text class="status-desc">{{getStatusDescription(repair.status)}}</text>
      </view>
    </view>

    <!-- 状态时间线 -->
    <view class="timeline-card card">
      <view class="card-header">
        <text class="card-title">处理进度</text>
      </view>
      <view class="timeline">
        <view class="timeline-item {{item.completed ? 'completed' : ''}} {{item.status === repair.status ? 'active' : ''}} {{item.isFirst ? 'first' : ''}} {{item.isLast ? 'last' : ''}}" 
              wx:for="{{timeline}}" 
              wx:key="status">
          <view class="timeline-dot"></view>
          <view class="timeline-content">
            <text class="timeline-status">{{item.title}}</text>
            <text class="timeline-time" wx:if="{{item.time}}">{{item.time}}</text>
            <text class="timeline-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 报修信息卡片 -->
    <view class="info-card card">
      <view class="card-header">
        <text class="card-title">报修信息</text>
      </view>
      <view class="info-list">
        <view class="info-item">
          <text class="info-label">报修标题</text>
          <text class="info-value">{{repair.title}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">房间号</text>
          <text class="info-value">{{repair.roomNumber || repair.room_number}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">报修类型</text>
          <text class="info-value">{{repair.typeText || repair.type || '一般维修'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">优先级</text>
          <view class="priority-tag {{priorityMap[repair.priority].class || 'priority-medium'}}">
            {{priorityMap[repair.priority].text || repair.priority}}
          </view>
        </view>
        <view class="info-item">
          <text class="info-label">报修人</text>
          <text class="info-value">{{repair.userName || repair.user_name || '-'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">联系电话</text>
          <text class="info-value">{{repair.phone || repair.contact_phone || '-'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">提交时间</text>
          <text class="info-value">{{repair.createdAt || repair.created_at}}</text>
        </view>
        <view class="info-item" wx:if="{{repair.updatedAt || repair.updated_at}}">
          <text class="info-label">更新时间</text>
          <text class="info-value">{{repair.updatedAt || repair.updated_at}}</text>
        </view>
      </view>
    </view>

    <!-- 报修描述 -->
    <view class="description-card card">
      <view class="card-header">
        <text class="card-title">问题描述</text>
      </view>
      <view class="description-text">{{repair.description || '暂无描述'}}</view>
    </view>

    <!-- 相关图片 -->
    <view class="images-card card" wx:if="{{repair.images && repair.images.length > 0}}">
      <view class="card-header">
        <text class="card-title">相关图片</text>
        <text class="image-count">共{{repair.images.length}}张</text>
      </view>
      <view class="image-grid">
        <view class="image-item" wx:for="{{repair.images}}" wx:key="*this">
          <image
            src="{{item}}"
            mode="aspectFill"
            data-url="{{item}}"
            bindtap="previewImage"
            lazy-load
          />
        </view>
      </view>
    </view>

    <!-- 处理记录 -->
    <view class="history-card card">
      <view class="card-header">
        <text class="card-title">处理记录</text>
      </view>
      <view class="history-list" wx:if="{{history.length > 0}}">
        <view class="history-item" wx:for="{{history}}" wx:key="id">
          <view class="history-header">
            <text class="history-action">{{item.actionText}}</text>
            <text class="history-time">{{item.timeFormatted}}</text>
          </view>
          <text class="history-operator" wx:if="{{item.operator}}">处理人：{{item.operator}}</text>
          <view class="history-content" wx:if="{{item.content || item.notes}}"
          >{{item.content || item.notes}}</view>
        </view>
      </view>
      <view class="empty-history" wx:else>
        <text class="empty-icon">📝</text>
        <text>暂无处理记录</text>
      </view>
    </view>

    <!-- 处理备注输入 -->
    <view class="notes-card card" wx:if="{{canUpdateStatus && repair.status !== 'closed' && repair.status !== 'completed'}}"
    >
      <view class="card-header">
        <text class="card-title">处理备注</text>
      </view>
      <textarea
        class="notes-textarea"
        placeholder="添加处理备注（可选，最多200字）"
        value="{{notes}}"
        bindinput="onNotesInput"
        maxlength="200"
      />
      <text class="char-count">{{notes.length}}/200</text>
    </view>

    <!-- 底部操作按钮 -->
    <view class="bottom-actions" wx:if="{{!loading && !error}}"
    >
      <!-- 学生操作 -->
      <view class="action-row" wx:if="{{canCancel}}">
        <button class="action-btn btn-danger" bindtap="cancelRepair">
          取消报修
        </button>
      </view>

      <!-- 维修工操作 -->
      <view class="action-row" wx:if="{{canTakeOrder || canComplete}}"
      >
        <button class="action-btn btn-primary" wx:if="{{canTakeOrder}}" bindtap="takeOrder"
        >
          接单
        </button>
        <button class="action-btn btn-success" wx:if="{{canComplete}}" bindtap="completeRepair"
        >
          完成工单
        </button>
      </view>

      <!-- 管理员操作 -->
      <view class="action-row" wx:if="{{canAssign || canUpdateStatus}}"
      >
        <button class="action-btn btn-warning" wx:if="{{canAssign}}" bindtap="markInProgress"
        >
          标记处理中
        </button>
        <button class="action-btn btn-success" wx:if="{{repair.status === 'in_progress'}}" bindtap="markCompleted"
        >
          标记完成
        </button>
      </view>

      <!-- 通用操作 -->
      <view class="action-row" wx:if="{{canDelete}}"
      >
        <button class="action-btn btn-secondary" bindtap="deleteRepair"
        >
          删除报修
        </button>
      </view>

      <!-- 联系管理员 -->
      <view class="action-row" wx:if="{{userRole === 'student' && repair.status !== 'closed' && repair.status !== 'completed'}}"
      >
        <button class="action-btn btn-ghost" bindtap="contactAdmin"
        >
          联系管理员
        </button>
      </view>
    </view>
  </view>
</view>
