/* pages/repairs/detail/index.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

.repair-detail {
  padding-bottom: 40rpx;
}

.status-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.status-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.status-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.status-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.info-section,
.description-section,
.images-section,
.history-section,
.admin-actions {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 160rpx;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.priority-tag {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.priority-tag.priority-high {
  background-color: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.priority-tag.priority-medium {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.priority-tag.priority-low {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.description-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
}

.history-list {
  margin-top: 10rpx;
}

.history-item {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
}

.history-item:last-child {
  margin-bottom: 0;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.history-action {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.history-time {
  font-size: 24rpx;
  color: #999;
}

.history-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.notes-input {
  margin-bottom: 20rpx;
}

.notes-textarea {
  width: 100%;
  min-height: 120rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.action-buttons {
  display: flex;
  flex-direction: column;
}

.action-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
  margin-bottom: 15rpx;
}

.action-btn:last-child {
  margin-bottom: 0;
}

.action-btn.warning {
  background-color: #faad14;
  color: #fff;
}

.action-btn.success {
  background-color: #52c41a;
  color: #fff;
}

.action-btn.danger {
  background-color: #ff4d4f;
  color: #fff;
}
