/* pages/repairs/detail/index.wxss */

.container {
  min-height: 100vh;
  background-color: var(--bg-primary);
  padding: var(--space-3);
  padding-bottom: 160rpx;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-3);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: var(--space-2);
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ===== 状态卡片 ===== */
.status-card {
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-lg);
  background: var(--primary-gradient);
}

/* 状态卡片颜色 */
.status-card.status-pending,
.status-card.status-Pending {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.status-card.status-in_progress,
.status-card.status-in-progress,
.status-card.status-In\ Progress {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
}

.status-card.status-completed,
.status-card.status-Completed {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.status-card.status-closed,
.status-card.status-Closed {
  background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
}

.status-icon {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 48rpx;
  margin-right: var(--space-3);
  backdrop-filter: blur(10rpx);
}

.status-info {
  flex: 1;
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  display: block;
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

/* ===== 卡片通用样式 ===== */
.card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-3);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-2);
  border-bottom: 2rpx solid var(--gray-100);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: flex;
  align-items: center;
}

.card-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--primary-gradient);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

/* ===== 状态时间线 ===== */
.timeline {
  padding-left: 20rpx;
}

.timeline-item {
  position: relative;
  padding-left: 48rpx;
  padding-bottom: var(--space-4);
  border-left: 4rpx solid var(--gray-200);
}

.timeline-item.last {
  padding-bottom: 0;
  border-left-color: transparent;
}

.timeline-item.first {
  padding-top: 0;
}

.timeline-dot {
  position: absolute;
  left: -14rpx;
  top: 4rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--gray-300);
  border: 4rpx solid #fff;
  box-shadow: var(--shadow-sm);
}

.timeline-item.active .timeline-dot {
  background: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.2);
}

.timeline-item.completed .timeline-dot {
  background: var(--success);
}

.timeline-content {
  margin-top: -4rpx;
}

.timeline-status {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.timeline-item.active .timeline-status {
  color: var(--primary-color);
}

.timeline-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
  display: block;
  margin-bottom: 8rpx;
}

.timeline-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* ===== 信息卡片 ===== */
.info-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.info-item {
  display: flex;
  align-items: flex-start;
  padding: var(--space-2) 0;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  word-break: break-all;
}

.priority-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
}

.priority-tag.priority-high {
  background: var(--danger-light);
  color: var(--danger);
}

.priority-tag.priority-medium {
  background: var(--warning-light);
  color: var(--warning);
}

.priority-tag.priority-low {
  background: var(--success-light);
  color: var(--success);
}

/* ===== 描述内容 ===== */
.description-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
  white-space: pre-wrap;
}

/* ===== 图片列表 ===== */
.image-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-2);
}

.image-item {
  width: 100%;
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
}

/* ===== 处理记录 ===== */
.history-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.history-item {
  background: var(--gray-50);
  border-radius: var(--radius-md);
  padding: var(--space-3);
  position: relative;
}

.history-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: var(--primary-gradient);
  border-radius: 3rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-2);
}

.history-action {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.history-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.history-operator {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-1);
  display: block;
}

.history-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  padding: var(--space-2);
  background: #fff;
  border-radius: var(--radius-sm);
  margin-top: var(--space-2);
}

.empty-history {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx var(--space-3);
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.empty-history .empty-icon {
  font-size: 60rpx;
  margin-bottom: var(--space-2);
  opacity: 0.6;
}

/* ===== 备注输入 ===== */
.notes-card .card-title::before {
  background: var(--warning);
}

.notes-textarea {
  width: 100%;
  min-height: 160rpx;
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  padding: var(--space-3);
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.notes-textarea:focus {
  border-color: var(--primary-color);
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-1);
}

/* ===== 底部操作栏 ===== */
.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: var(--space-3);
  padding-bottom: calc(var(--space-3) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-3) + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  z-index: 100;
}

.action-row {
  display: flex;
  gap: var(--space-2);
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
  transition: all 0.2s ease;
  text-align: center;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.98);
}

/* 按钮样式 */
.action-btn.btn-primary {
  background: var(--primary-gradient);
  color: #fff;
  box-shadow: var(--shadow-md);
}

.action-btn.btn-success {
  background: var(--success);
  color: #fff;
  box-shadow: var(--shadow-md);
}

.action-btn.btn-warning {
  background: var(--warning);
  color: #fff;
  box-shadow: var(--shadow-md);
}

.action-btn.btn-danger {
  background: var(--danger);
  color: #fff;
  box-shadow: var(--shadow-md);
}

.action-btn.btn-secondary {
  background: var(--gray-100);
  color: var(--text-primary);
  border: 2rpx solid var(--gray-200);
}

.action-btn.btn-ghost {
  background: transparent;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-3);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: var(--space-3);
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-3);
}

/* ===== 错误状态 ===== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--space-3);
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: var(--space-3);
}

.error-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-3);
  text-align: center;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.retry-btn::after {
  border: none;
}
