/* pages/repairs/list/index.wxss */

.container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: var(--space-3);
  padding-bottom: calc(160rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ----- 页面头部 ----- */
.page-header {
  margin-bottom: var(--space-3);
}

.page-header .heading-2 {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.page-header .subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: var(--space-1);
}

/* ----- 搜索栏 ----- */
.search-section {
  margin-bottom: var(--space-3);
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-full);
  padding: var(--space-2) var(--space-3);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--gray-200);
}

.search-icon {
  font-size: 28rpx;
  margin-right: var(--space-2);
  color: var(--text-tertiary);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  height: 48rpx;
}

.search-input::placeholder {
  color: var(--text-tertiary);
}

/* ----- 筛选区域 ----- */
.filter-section {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-2) 0;
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-sm);
}

.filter-scroll {
  white-space: nowrap;
  padding: 0 var(--space-2);
}

.filter-item {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 28rpx;
  margin: 0 8rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  background: var(--gray-100);
  transition: all 0.2s ease;
}

.filter-item:first-child {
  margin-left: var(--space-2);
}

.filter-item:last-child {
  margin-right: var(--space-2);
}

.filter-item.active {
  background: var(--primary-gradient);
  color: #fff;
  box-shadow: var(--shadow-md);
}

.filter-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.dot-pending {
  background: var(--warning);
}

.dot-in_progress {
  background: var(--info);
}

.dot-completed {
  background: var(--success);
}

.dot-closed {
  background: var(--gray-400);
}

.filter-item.active .filter-dot {
  background: #fff;
}

/* ----- 优先级筛选 ----- */
.priority-filter-section {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--space-2) var(--space-3);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-sm);
}

.filter-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-right: var(--space-2);
  font-weight: 500;
}

.priority-options {
  display: flex;
  gap: var(--space-2);
  flex: 1;
}

.priority-option {
  padding: 12rpx 32rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-secondary);
  background: var(--gray-100);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.priority-option.active {
  background: #fff;
  box-shadow: var(--shadow-sm);
}

.priority-option.priority-high {
  color: var(--danger);
}

.priority-option.priority-high.active {
  border-color: var(--danger);
  background: var(--danger-light);
}

.priority-option.priority-medium {
  color: var(--warning);
}

.priority-option.priority-medium.active {
  border-color: var(--warning);
  background: var(--warning-light);
}

.priority-option.priority-low {
  color: var(--success);
}

.priority-option.priority-low.active {
  border-color: var(--success);
  background: var(--success-light);
}

/* ----- 报修列表 ----- */
.repair-list {
  padding-bottom: var(--space-3);
}

.repair-card {
  background: #fff;
  border-radius: var(--radius-xl);
  padding: var(--space-3);
  margin-bottom: var(--space-3);
  box-shadow: var(--shadow-md);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  position: relative;
  overflow: hidden;
}

.repair-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.repair-card.status-pending::before {
  background: var(--warning);
  opacity: 1;
}

.repair-card.status-in_progress::before {
  background: var(--info);
  opacity: 1;
}

.repair-card.status-completed::before {
  background: var(--success);
  opacity: 1;
}

.repair-card.status-closed::before {
  background: var(--gray-400);
  opacity: 1;
}

.repair-card:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-lg);
}

.repair-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-3);
  border-bottom: 1rpx solid var(--gray-100);
}

.repair-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: var(--space-2);
  line-height: 1.4;
  word-break: break-all;
}

.repair-status {
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

/* 状态标签样式 */
.repair-status.status-pending {
  background: var(--warning-light);
  color: var(--warning);
}

.repair-status.status-in_progress {
  background: var(--info-light);
  color: var(--info);
}

.repair-status.status-completed {
  background: var(--success-light);
  color: var(--success);
}

.repair-status.status-closed {
  background: var(--gray-100);
  color: var(--gray-500);
}

.repair-info {
  margin-bottom: var(--space-3);
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--space-2);
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-right: var(--space-2);
  min-width: 100rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  flex: 1;
  word-break: break-all;
}

.info-value.desc-text {
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.priority-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
}

.priority-tag.priority-high {
  background: var(--danger-light);
  color: var(--danger);
}

.priority-tag.priority-medium {
  background: var(--warning-light);
  color: var(--warning);
}

.priority-tag.priority-low {
  background: var(--success-light);
  color: var(--success);
}

.repair-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--space-3);
  border-top: 1rpx solid var(--gray-100);
}

.repair-actions {
  display: flex;
  gap: var(--space-2);
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-md);
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.action-btn.btn-cancel {
  background: var(--gray-100);
  color: var(--text-secondary);
  border: 1rpx solid var(--gray-200);
}

.action-btn.btn-cancel:active {
  background: var(--gray-200);
}

.action-btn.btn-take {
  background: var(--info);
  color: #fff;
}

.action-btn.btn-take:active {
  background: var(--info-light);
  color: var(--info);
}

.action-btn.btn-delete {
  background: var(--danger-light);
  color: var(--danger);
  border: 1rpx solid var(--danger-light);
}

.action-btn.btn-delete:active {
  background: var(--danger);
  color: #fff;
}

.view-detail {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.view-detail .arrow {
  margin-left: 8rpx;
  font-size: 32rpx;
  line-height: 1;
}

/* ----- 提交按钮 ----- */
.submit-btn-wrapper {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  z-index: 100;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 400rpx;
  height: 96rpx;
  background: var(--primary-gradient);
  border-radius: var(--radius-full);
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.4);
  transition: all 0.2s ease;
}

.submit-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.submit-icon {
  font-size: 40rpx;
  color: #fff;
  margin-right: 12rpx;
  font-weight: 300;
  line-height: 1;
}

.submit-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

/* ----- 空状态 ----- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--space-3);
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: var(--space-3);
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: var(--space-2);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  max-width: 400rpx;
}

/* ----- 加载状态 ----- */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx var(--space-3);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: var(--space-3);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ----- 阻止冒泡辅助类 ----- */
.prevent-bubble {
  pointer-events: auto;
}
