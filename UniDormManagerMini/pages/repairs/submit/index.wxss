/* pages/repairs/submit/index.wxss */
.container-safe {
  padding: var(--space-3);
  padding-bottom: calc(var(--space-4) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--space-4) + env(safe-area-inset-bottom));
  background-color: var(--bg-primary);
  min-height: 100vh;
}

/* 页面头部 */
.page-header {
  text-align: center;
  padding-top: var(--space-2);
}

/* 提示卡片 */
.tip-card {
  display: flex;
  align-items: flex-start;
  padding: var(--space-3);
}

.tip-icon {
  font-size: 40rpx;
  margin-right: var(--space-2);
  flex-shrink: 0;
}

.tip-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.95);
  line-height: 1.6;
  margin-bottom: 4rpx;
}

/* 表单卡片 */
.form-card {
  padding: var(--space-4);
}

.form-group {
  margin-bottom: var(--space-4);
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.form-label.required::before {
  content: '*';
  color: var(--danger);
  margin-right: 6rpx;
}

.form-label .caption {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 400;
  margin-left: 8rpx;
}

/* 输入框样式 */
.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 var(--space-3);
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.form-input:focus {
  background: #fff;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.form-input.error {
  border-color: var(--danger);
  background: var(--danger-light);
}

.form-input.placeholder {
  color: var(--text-tertiary);
}

/* 错误提示 */
.error-text {
  font-size: 24rpx;
  color: var(--danger);
  margin-top: var(--space-1);
  animation: shakeIn 0.3s ease;
}

@keyframes shakeIn {
  0% { opacity: 0; transform: translateX(-10rpx); }
  100% { opacity: 1; transform: translateX(0); }
}

/* 选择器样式 */
.picker-wrapper {
  position: relative;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--text-tertiary);
  transition: transform 0.2s ease;
}

/* 优先级选择器 - 卡片式单选 */
.priority-selector {
  display: flex;
  gap: var(--space-2);
}

.priority-card {
  flex: 1;
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  padding: var(--space-3);
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  transition: all 0.2s ease;
}

.priority-card:active {
  transform: scale(0.98);
}

.priority-card.active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-md);
}

.priority-card.active.low {
  background: var(--success-light);
  border-color: var(--success);
}

.priority-card.active.medium {
  background: var(--warning-light);
  border-color: var(--warning);
}

.priority-card.active.high {
  background: var(--danger-light);
  border-color: var(--danger);
}

.priority-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--gray-300);
  margin-bottom: var(--space-1);
  transition: all 0.2s ease;
}

.priority-card.active.low .priority-dot {
  background: var(--success);
  box-shadow: 0 0 8rpx var(--success);
}

.priority-card.active.medium .priority-dot {
  background: var(--warning);
  box-shadow: 0 0 8rpx var(--warning);
}

.priority-card.active.high .priority-dot {
  background: var(--danger);
  box-shadow: 0 0 8rpx var(--danger);
}

.priority-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.priority-card.active .priority-label {
  color: inherit;
}

.priority-card.active.low .priority-label {
  color: var(--success);
}

.priority-card.active.medium .priority-label {
  color: var(--warning);
}

.priority-card.active.high .priority-label {
  color: var(--danger);
}

.priority-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.priority-card.active.low .priority-desc {
  color: var(--success);
  opacity: 0.8;
}

.priority-card.active.medium .priority-desc {
  color: var(--warning);
  opacity: 0.8;
}

.priority-card.active.high .priority-desc {
  color: var(--danger);
  opacity: 0.8;
}

/* 文本域样式 */
.form-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: var(--space-3);
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  box-sizing: border-box;
}

.form-textarea:focus {
  background: #fff;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.form-textarea.error {
  border-color: var(--danger);
  background: var(--danger-light);
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-1);
}

/* 图片上传区域 */
.image-upload-area {
  margin-top: var(--space-1);
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.image-item:active {
  transform: scale(0.95);
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(239, 68, 68, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4rpx);
  transition: all 0.2s ease;
}

.delete-btn:active {
  transform: scale(0.9);
}

.delete-icon {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--gray-300);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--gray-50);
  transition: all 0.2s ease;
}

.upload-btn:active {
  background: var(--gray-100);
  border-color: var(--primary-color);
  transform: scale(0.98);
}

.upload-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-2);
  box-shadow: var(--shadow-sm);
}

.upload-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 提交区域 */
.submit-section {
  padding: var(--space-4) 0;
}

.submit-btn {
  position: relative;
  height: 96rpx !important;
  border-radius: var(--radius-lg) !important;
  box-shadow: var(--shadow-lg);
}

.submit-btn.submitting {
  opacity: 0.8;
}

.submit-btn::after {
  border: none;
}

.submit-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: var(--space-2);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.submit-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-3);
}

/* 占位符颜色 */
::placeholder {
  color: var(--text-tertiary);
}
