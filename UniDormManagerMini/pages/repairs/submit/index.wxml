<!--pages/repairs/submit/index.wxml-->
<view class="container-safe">
  <!-- 页面标题 -->
  <view class="page-header mb-4">
    <text class="heading-2">提交报修</text>
    <text class="subtitle mt-1">请填写报修信息，我们会尽快处理</text>
  </view>

  <!-- 提示卡片 -->
  <view class="card-gradient tip-card mb-4">
    <view class="tip-icon">💡</view>
    <view class="tip-content">
      <text class="tip-text">• 请如实填写报修信息</text>
      <text class="tip-text">• 上传图片帮助维修人员了解情况</text>
      <text class="tip-text">• 高优先级报修会优先处理</text>
    </view>
  </view>

  <!-- 报修表单 -->
  <view class="form-card card">
    <!-- 标题 -->
    <view class="form-group">
      <view class="form-label required">报修标题</view>
      <input
        class="form-input {{errors.title ? 'error' : ''}}"
        placeholder="请输入报修标题，如：水龙头漏水"
        value="{{title}}"
        bindinput="onTitleInput"
        bindblur="validateField"
        data-field="title"
        maxlength="50"
        confirm-type="next"
      />
      <view wx:if="{{errors.title}}" class="error-text">{{errors.title}}</view>
    </view>

    <!-- 房间号 -->
    <view class="form-group">
      <view class="form-label required">房间号</view>
      <picker
        class="picker-wrapper"
        mode="selector"
        range="{{roomOptions}}"
        bindchange="onRoomChange"
      >
        <view class="form-input picker {{!roomNumber ? 'placeholder' : ''}} {{errors.roomNumber ? 'error' : ''}}">
          <text>{{roomNumber || '请选择房间号'}}</text>
          <text class="picker-arrow">▾</text>
        </view>
      </picker>
      <view wx:if="{{errors.roomNumber}}" class="error-text">{{errors.roomNumber}}</view>
    </view>

    <!-- 报修类型 -->
    <view class="form-group">
      <view class="form-label required">报修类型</view>
      <picker
        class="picker-wrapper"
        mode="selector"
        range="{{repairTypes}}"
        range-key="label"
        bindchange="onTypeChange"
      >
        <view class="form-input picker {{!repairType ? 'placeholder' : ''}} {{errors.repairType ? 'error' : ''}}">
          <text>{{selectedTypeLabel}}</text>
          <text class="picker-arrow">▾</text>
        </view>
      </picker>
      <view wx:if="{{errors.repairType}}" class="error-text">{{errors.repairType}}</view>
    </view>

    <!-- 优先级 - 卡片式单选 -->
    <view class="form-group">
      <view class="form-label">优先级</view>
      <view class="priority-selector">
        <view 
          wx:for="{{priorityOptions}}" 
          wx:key="value"
          class="priority-card {{priority === item.value ? 'active ' + item.value : ''}}"
          data-value="{{item.value}}"
          bindtap="onPrioritySelect"
        >
          <view class="priority-dot"></view>
          <text class="priority-label">{{item.label}}</text>
          <text class="priority-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 详细描述 -->
    <view class="form-group">
      <view class="form-label required">详细描述</view>
      <textarea
        class="form-textarea {{errors.description ? 'error' : ''}}"
        placeholder="请详细描述故障情况、位置、时间等信息"
        value="{{description}}"
        bindinput="onDescriptionInput"
        bindblur="validateField"
        data-field="description"
        maxlength="500"
        auto-height
        confirm-type="done"
        show-confirm-bar="{{false}}"
      />
      <view class="char-count">{{description.length}}/500</view>
      <view wx:if="{{errors.description}}" class="error-text">{{errors.description}}</view>
    </view>

    <!-- 图片上传 -->
    <view class="form-group mb-0">
      <view class="form-label">相关图片 <text class="caption">（最多3张）</text></view>
      <view class="image-upload-area">
        <view class="image-list">
          <!-- 已上传图片 -->
          <view
            class="image-item"
            wx:for="{{images}}"
            wx:key="*this"
            bindtap="previewImage"
            data-url="{{item}}"
          >
            <image
              class="uploaded-image"
              src="{{item}}"
              mode="aspectFill"
            ></image>
            <view
              class="delete-btn"
              data-index="{{index}}"
              catchtap="deleteImage"
            >
              <text class="delete-icon">✕</text>
            </view>
          </view>

          <!-- 添加图片按钮 -->
          <view
            class="upload-btn"
            wx:if="{{images.length < 3}}"
            bindtap="chooseImage"
          >
            <view class="upload-icon-wrapper">
              <text class="upload-icon">+</text>
            </view>
            <text class="upload-text">添加图片</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button
      class="btn btn-primary btn-lg btn-block submit-btn {{submitting ? 'submitting' : ''}}"
      bindtap="submitRepair"
      disabled="{{submitting}}"
    >
      <view wx:if="{{submitting}}" class="submit-spinner"></view>
      <text>{{submitting ? '提交中...' : '提交报修'}}</text>
    </button>
    <text class="submit-hint">提交后工作人员将在24小时内联系您</text>
  </view>
</view>
