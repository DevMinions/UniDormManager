<!--pages/repairs/submit/index.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">提交报修</text>
    <text class="page-subtitle">请填写报修信息，我们会尽快处理</text>
  </view>

  <!-- 提示卡片 -->
  <view class="tip-card">
    <view class="tip-icon">💡</view>
    <view class="tip-content">
      <text class="tip-text">请如实填写报修信息</text>
      <text class="tip-text">上传相关图片可以帮助维修人员更好地了解情况</text>
      <text class="tip-text">高优先级报修会优先处理，请合理选择</text>
    </view>
  </view>

  <!-- 报修表单 -->
  <view class="form-section">
    <!-- 标题 -->
    <view class="form-item required">
      <view class="form-label">报修标题</view>
      <input
        class="form-input"
        placeholder="请输入报修标题，如：水龙头漏水"
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="50"
        confirm-type="text"
      />
    </view>

    <!-- 房间号 -->
    <view class="form-item required">
      <view class="form-label">房间号</view>
      <input
        class="form-input"
        placeholder="请输入你的房间号，如：A301"
        value="{{roomNumber}}"
        bindinput="onRoomNumberInput"
        maxlength="20"
        confirm-type="text"
      />
    </view>

    <!-- 报修类型 -->
    <view class="form-item">
      <view class="form-label">报修类型</view>
      <picker
        class="form-picker"
        mode="selector"
        range="{{repairTypes}}"
        range-key="label"
        bindchange="onTypeChange"
      >
        <view class="picker">
          {{selectedTypeLabel}}
        </view>
      </picker>
    </view>

    <!-- 优先级 -->
    <view class="form-item">
      <view class="form-label">优先级</view>
      <picker
        class="form-picker"
        mode="selector"
        range="{{priorityOptions}}"
        range-key="label"
        bindchange="onPriorityChange"
      >
        <view class="picker">
          {{selectedPriorityLabel}}
        </view>
      </picker>
    </view>

    <!-- 详细描述 -->
    <view class="form-item required">
      <view class="form-label">详细描述</view>
      <textarea
        class="form-textarea"
        placeholder="请详细描述故障情况、位置、时间等信息"
        value="{{description}}"
        bindinput="onDescriptionInput"
        maxlength="500"
        auto-height
        confirm-type="textarea"
        show-confirm-bar="{{false}}"
      />
      <view class="char-count">{{description.length}}/500</view>
    </view>

    <!-- 图片上传 -->
    <view class="form-item">
      <view class="form-label">相关图片（可选）</view>
      <view class="image-upload">
        <view class="image-list">
          <view
            class="image-item"
            wx:for="{{images}}"
            wx:key="*this"
          >
            <image
              class="uploaded-image"
              src="{{item}}"
              mode="aspectFill"
              data-url="{{item}}"
              bindtap="previewImage"
            ></image>
            <view
              class="delete-btn"
              data-index="{{index}}"
              bindtap="deleteImage"
            >×</view>
          </view>

          <view
            class="upload-btn"
            wx:if="{{images.length < 3}}"
            bindtap="chooseImage"
          >
            <view class="upload-icon">＋</view>
            <text class="upload-text">添加图片</text>
          </view>
        </view>
        <text class="upload-hint">最多上传3张图片</text>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button
        class="submit-btn {{submitting ? 'disabled' : ''}}"
        bindtap="submitRepair"
        disabled="{{submitting}}"
        formType="submit"
      >
        {{submitting ? '提交中...' : '提交报修'}}
      </button>
    </view>
  </view>
</view>
