<!--pages/login/login.wxml-->
<view class="login-container">
  <view class="login-header">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="title">宿舍管理系统</text>
    <text class="subtitle">UniDorm Manager</text>
  </view>

  <view class="login-content">
    <view class="welcome-text">
      <text class="welcome-title">欢迎使用</text>
      <text class="welcome-desc">请使用微信登录以继续</text>
    </view>

    <view class="login-actions">
      <!-- 微信登录按钮 -->
      <button
        class="login-btn {{loading ? 'disabled' : ''}}"
        open-type="getUserInfo"
        bindgetuserinfo="getUserInfo"
        bindtap="handleLogin"
        disabled="{{loading}}"
      >
        <text wx:if="{{loading}}">登录中...</text>
        <text wx:else>微信一键登录</text>
      </button>

      <!-- 用户信息展示 -->
      <view class="user-info" wx:if="{{hasUserInfo && userInfo}}">
        <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <text class="nickname">{{userInfo.nickName}}</text>
      </view>
    </view>

    <view class="login-tips">
      <text>• 首次登录将自动创建账号</text>
      <text>• 管理员请联系系统管理员分配权限</text>
    </view>
  </view>

  <view class="login-footer">
    <text class="copyright">© 2025 UniDorm Manager</text>
  </view>
</view>
