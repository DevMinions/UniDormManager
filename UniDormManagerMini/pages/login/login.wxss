/* pages/login/login.wxss */

.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--primary-gradient);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 装饰背景 */
.login-container::before {
  content: '';
  position: absolute;
  top: -20%;
  right: -30%;
  width: 600rpx;
  height: 600rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.login-container::after {
  content: '';
  position: absolute;
  bottom: -10%;
  left: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
  margin-bottom: 80rpx;
  position: relative;
  z-index: 1;
}

.logo-wrapper {
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.logo {
  width: 120rpx;
  height: 120rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.2));
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
  letter-spacing: 2rpx;
}

.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.welcome-text {
  text-align: center;
  margin-bottom: 80rpx;
}

.welcome-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
}

.welcome-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-actions {
  margin-bottom: 60rpx;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: #fff;
  color: var(--primary-color);
  font-size: 32rpx;
  font-weight: 700;
  border-radius: var(--radius-full);
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::before {
  content: '💬';
  margin-right: 16rpx;
  font-size: 36rpx;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.login-btn.disabled {
  opacity: 0.7;
  pointer-events: none;
}

.user-info {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  padding: 24rpx 40rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-full);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.nickname {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.login-tips {
  text-align: center;
  margin-top: auto;
  margin-bottom: 40rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.tip-dot {
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.login-footer {
  text-align: center;
  padding-top: 40rpx;
  padding-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.copyright {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 1rpx;
}

/* 加载动画 */
@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.6;
  }
}

.loading-dots::after {
  content: '...';
  animation: dots 1.5s steps(4, end) infinite;
}

@keyframes dots {
  0%, 20% { content: ''; }
  40% { content: '.'; }
  60% { content: '..'; }
  80%, 100% { content: '...'; }
}
