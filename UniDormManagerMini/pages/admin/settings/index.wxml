<!--pages/admin/settings/index.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="heading-2">⚙️ 系统设置</text>
    <text class="subtitle">管理系统配置和功能选项</text>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载配置中...</text>
  </view>

  <!-- 设置内容 -->
  <view wx:else>
    <!-- 基础设置 -->
    <view class="settings-section">
      <view class="section-header">
        <text class="section-title">📋 基础设置</text>
      </view>

      <view class="settings-list">
        <view class="setting-item">
          <view class="setting-label">
            <text class="label-title">系统名称</text>
            <text class="label-desc">显示在页面标题栏的名称</text>
          </view>
          <input
            class="setting-input"
            value="{{basicSettings.systemName}}"
            data-field="systemName"
            bindinput="onBasicInput"
            placeholder="请输入系统名称"
          />
        </view>

        <view class="setting-item">
          <view class="setting-label">
            <text class="label-title">联系电话</text>
            <text class="label-desc">用于联系管理员</text>
          </view>
          <view class="setting-with-action">
            <input
              class="setting-input"
              value="{{basicSettings.contactPhone}}"
              data-field="contactPhone"
              bindinput="onBasicInput"
              placeholder="请输入联系电话"
            />
            <view class="setting-action" data-type="phone" bindtap="testContact">
              <text>📞</text>
            </view>
          </view>
        </view>

        <view class="setting-item">
          <view class="setting-label">
            <text class="label-title">联系邮箱</text>
            <text class="label-desc">用于邮件联系</text>
          </view>
          <view class="setting-with-action">
            <input
              class="setting-input"
              value="{{basicSettings.contactEmail}}"
              data-field="contactEmail"
              bindinput="onBasicInput"
              placeholder="请输入联系邮箱"
            />
            <view class="setting-action" data-type="email" bindtap="testContact">
              <text>📧</text>
            </view>
          </view>
        </view>

        <view class="setting-item switch-item">
          <view class="setting-label">
            <text class="label-title">启用公告功能</text>
            <text class="label-desc">是否允许发布和查看公告</text>
          </view>
          <switch
            checked="{{basicSettings.enableAnnouncement}}"
            data-field="enableAnnouncement"
            bindchange="onBasicSwitch"
            color="#667eea"
          />
        </view>
      </view>
    </view>

    <!-- 报修设置 -->
    <view class="settings-section">
      <view class="section-header">
        <text class="section-title">🔧 报修设置</text>
      </view>

      <view class="settings-list">
        <view class="setting-item switch-item">
          <view class="setting-label">
            <text class="label-title">允许匿名报修</text>
            <text class="label-desc">学生可以匿名提交报修</text>
          </view>
          <switch
            checked="{{repairSettings.allowAnonymous}}"
            data-field="allowAnonymous"
            bindchange="onRepairSwitch"
            color="#667eea"
          />
        </view>

        <view class="setting-item switch-item">
          <view class="setting-label">
            <text class="label-title">自动分配维修工</text>
            <text class="label-desc">系统自动分配空闲维修工</text>
          </view>
          <switch
            checked="{{repairSettings.autoAssign}}"
            data-field="autoAssign"
            bindchange="onRepairSwitch"
            color="#667eea"
          />
        </view>

        <view class="setting-item">
          <view class="setting-label">
            <text class="label-title">紧急报修阈值</text>
            <text class="label-desc">超过此小时数标记为紧急</text>
          </view>
          <picker 
            bindchange="onThresholdChange" 
            range="{{['12小时', '24小时', '48小时', '72小时']}}"
            value="{{[12, 24, 48, 72].indexOf(repairSettings.urgentThreshold)}}"
          >
            <view class="setting-picker">
              <text class="picker-value">{{repairSettings.urgentThreshold}} 小时</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="setting-item switch-item">
          <view class="setting-label">
            <text class="label-title">提交时通知</text>
            <text class="label-desc">报修提交后发送通知</text>
          </view>
          <switch
            checked="{{repairSettings.notifyOnSubmit}}"
            data-field="notifyOnSubmit"
            bindchange="onRepairSwitch"
            color="#667eea"
          />
        </view>

        <view class="setting-item switch-item">
          <view class="setting-label">
            <text class="label-title">完成时通知</text>
            <text class="label-desc">报修完成后发送通知</text>
          </view>
          <switch
            checked="{{repairSettings.notifyOnComplete}}"
            data-field="notifyOnComplete"
            bindchange="onRepairSwitch"
            color="#667eea"
          />
        </view>
      </view>
    </view>

    <!-- 入住设置 -->
    <view class="settings-section">
      <view class="section-header">
        <text class="section-title">🏠 入住设置</text>
      </view>

      <view class="settings-list">
        <view class="setting-item">
          <view class="setting-label">
            <text class="label-title">每房间最大人数</text>
            <text class="label-desc">单个房间可容纳的最大人数</text>
          </view>
          <input
            class="setting-input"
            type="number"
            value="{{checkinSettings.maxOccupancyPerRoom}}"
            data-field="maxOccupancyPerRoom"
            bindinput="onCheckinInput"
          />
        </view>

        <view class="setting-item switch-item">
          <view class="setting-label">
            <text class="label-title">允许自助入住</text>
            <text class="label-desc">学生可自主完成入住手续</text>
          </view>
          <switch
            checked="{{checkinSettings.allowSelfCheckin}}"
            data-field="allowSelfCheckin"
            bindchange="onCheckinSwitch"
            color="#667eea"
          />
        </view>

        <view class="setting-item switch-item">
          <view class="setting-label">
            <text class="label-title">入住需审批</text>
            <text class="label-desc">入住申请需要管理员审核</text>
          </view>
          <switch
            checked="{{checkinSettings.checkinRequireApproval}}"
            data-field="checkinRequireApproval"
            bindchange="onCheckinSwitch"
            color="#667eea"
          />
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <view class="btn-reset" bindtap="resetToDefault">
        <text>↺ 恢复默认</text>
      </view>
      <view class="btn-save" bindtap="saveSettings">
        <text>✓ 保存设置</text>
      </view>
    </view>
  </view>
</view>
