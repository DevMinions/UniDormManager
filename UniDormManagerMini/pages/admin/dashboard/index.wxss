/* pages/admin/dashboard/index.wxss */

/* 页面标题 */
.page-header {
  margin-bottom: 32rpx;
}

.page-header .subtitle {
  display: block;
  margin-top: 8rpx;
  color: var(--text-secondary);
}

/* 统计卡片网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.stat-card.highlight::before {
  background: linear-gradient(90deg, #10b981, #059669);
}

.stat-card.warning::before {
  background: linear-gradient(90deg, #f59e0b, #d97706);
}

.stat-card.success::before {
  background: linear-gradient(90deg, #10b981, #059669);
}

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background: rgba(102, 126, 234, 0.1);
}

.users-icon { background: rgba(102, 126, 234, 0.1); }
.rooms-icon { background: rgba(16, 185, 129, 0.1); }
.occupancy-icon { background: rgba(59, 130, 246, 0.1); }
.repair-today-icon { background: rgba(245, 158, 11, 0.1); }
.repair-pending-icon { background: rgba(239, 68, 68, 0.1); }
.new-users-icon { background: rgba(16, 185, 129, 0.1); }

.stat-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.stat-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.stat-trend {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.stat-trend.up {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.stat-trend.down {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

.stat-detail {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
}

.detail-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.stat-badge {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  background: #ef4444;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 24rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.stat-alert {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  background: rgba(245, 158, 11, 0.15);
  color: #d97706;
  padding: 4rpx 12rpx;
  border-radius: 24rpx;
  font-size: 20rpx;
  font-weight: 500;
}

/* 图表区域 */
.charts-section {
  margin-bottom: 32rpx;
}

.chart-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.chart-header {
  margin-bottom: 24rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 趋势图表 */
.trend-chart {
  height: 360rpx;
  display: flex;
  position: relative;
}

.chart-y-axis {
  width: 80rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-end;
  padding-right: 16rpx;
  border-right: 1rpx solid var(--gray-200);
}

.y-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.chart-content {
  flex: 1;
  position: relative;
  padding-left: 16rpx;
}

.trend-line {
  position: absolute;
  top: 0;
  left: 16rpx;
  right: 0;
  bottom: 60rpx;
  border-left: 1rpx dashed var(--gray-200);
  border-bottom: 1rpx solid var(--gray-200);
}

.trend-point {
  position: absolute;
  transform: translate(-50%, 50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.point-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #667eea;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.4);
}

.point-value {
  font-size: 20rpx;
  color: #667eea;
  font-weight: 600;
  margin-top: 8rpx;
  white-space: nowrap;
}

.chart-x-axis {
  position: absolute;
  bottom: 20rpx;
  left: 16rpx;
  right: 0;
  height: 40rpx;
}

.x-label {
  position: absolute;
  transform: translateX(-50%);
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 报修类型分布 */
.type-distribution {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.type-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
}

.legend-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.legend-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.type-bars {
  height: 48rpx;
  display: flex;
  border-radius: 24rpx;
  overflow: hidden;
}

.type-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.bar-label {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

/* 楼栋列表 */
.building-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.building-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.building-info {
  width: 140rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.building-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.building-detail {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.building-progress {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bg {
  flex: 1;
  height: 16rpx;
  background: var(--gray-100);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

.progress-text {
  width: 80rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: right;
}

/* 快捷操作 */
.quick-actions {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease;
}

.action-item:active {
  transform: scale(0.95);
}

.action-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.action-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 加载样式 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}
