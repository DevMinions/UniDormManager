<!--pages/admin/users/index.wxml-->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-title">
      <text class="heading-2">👥 用户管理</text>
      <text class="user-count" wx:if="{{!loading}}">共 {{total}} 人</text>
    </view>
    <view class="add-btn" bindtap="openAddModal">
      <text class="add-icon">+</text>
      <text>添加用户</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索姓名、学号/工号"
        value="{{keyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-section">
    <view class="filter-group">
      <view 
        class="filter-item {{selectedRole === 'all' ? 'active' : ''}}"
        data-role="all"
        bindtap="filterRole"
      >
        全部角色
      </view>
      <view 
        class="filter-item {{selectedRole === 'student' ? 'active' : ''}}"
        data-role="student"
        bindtap="filterRole"
      >
        学生
      </view>
      <view 
        class="filter-item {{selectedRole === 'maintenance' ? 'active' : ''}}"
        data-role="maintenance"
        bindtap="filterRole"
      >
        维修工
      </view>
      <view 
        class="filter-item {{selectedRole === 'dorm_manager' ? 'active' : ''}}"
        data-role="dorm_manager"
        bindtap="filterRole"
      >
        宿管
      </view>
    </view>
    
    <view class="filter-group">
      <view 
        class="filter-item {{selectedStatus === 'all' ? 'active' : ''}}"
        data-status="all"
        bindtap="filterStatus"
      >
        全部状态
      </view>
      <view 
        class="filter-item {{selectedStatus === 'active' ? 'active' : ''}}"
        data-status="active"
        bindtap="filterStatus"
      >
        启用
      </view>
      <view 
        class="filter-item {{selectedStatus === 'disabled' ? 'active' : ''}}"
        data-status="disabled"
        bindtap="filterStatus"
      >
        禁用
      </view>
    </view>
  </view>

  <!-- 用户列表 -->
  <view class="user-list">
    <!-- 加载中 -->
    <view class="loading" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:elif="{{userList.length === 0}}">
      <view class="empty-icon">👤</view>
      <text class="empty-title">暂无用户</text>
      <text class="empty-desc">点击右上角添加用户</text>
    </view>

    <!-- 列表内容 -->
    <view class="user-items" wx:else>
      <view class="user-card" wx:for="{{userList}}" wx:key="id">
        <view class="user-main">
          <view class="user-avatar">
            <text>{{item.realName[0]}}</text>
          </view>
          
          <view class="user-info">
            <view class="info-row">
              <text class="user-name">{{item.realName}}</text>
              <view class="role-tag {{item.role}}">{{item.roleName}}</view>
              <view class="status-tag {{item.status}}">{{item.status === 'active' ? '启用' : '禁用'}}</view>
            </view>
            
            <view class="info-row secondary">
              <text class="user-id" wx:if="{{item.studentId}}">学号: {{item.studentId}}</text>
              <text class="user-username" wx:else>用户名: {{item.username}}</text>
              <text class="divider" wx:if="{{item.phone}}">|</text>
              <text class="user-phone" wx:if="{{item.phone}}">{{item.phone}}</text>
            </view>
            
            <view class="info-row tertiary">
              <text>注册: {{item.createdAt}}</text>
            </view>
          </view>
        </view>
        
        <view class="user-actions">
          <view 
            class="action-btn edit"
            data-user="{{item}}"
            bindtap="openEditModal"
          >
            编辑
          </view>
          
          <view 
            class="action-btn password"
            data-user="{{item}}"
            bindtap="openPasswordModal"
          >
            重置密码
          </view>
          
          <view 
            class="action-btn {{item.status === 'active' ? 'disable' : 'enable'}}"
            data-user="{{item}}"
            bindtap="toggleUserStatus"
          >
            {{item.status === 'active' ? '禁用' : '启用'}}
          </view>
        </view>
      </view>

      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{hasMore}}">
        <view class="load-more-btn" bindtap="loadMore">
          <text>加载更多</text>
        </view>
      </view>
      
      <view class="no-more" wx:else>
        <text>没有更多数据了</text>
      </view>
    </view>
  </view>

  <!-- 用户编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showUserModal}}" bindtap="closeUserModal"></view>
  <view class="modal {{showUserModal ? 'show' : ''}}">
    <view class="modal-header">
      <text class="modal-title">{{isEditing ? '编辑用户' : '添加用户'}}</text>
      <view class="modal-close" bindtap="closeUserModal">✕</view>
    </view>
    
    <view class="modal-body">
      <view class="form-item">
        <text class="form-label">用户名</text>
        <input 
          class="form-input" 
          placeholder="请输入用户名"
          value="{{formData.username}}"
          data-field="username"
          bindinput="onFormInput"
          disabled="{{isEditing}}"
        />
      </view>
      
      <view class="form-item">
        <text class="form-label">姓名</text>
        <input 
          class="form-input" 
          placeholder="请输入姓名"
          value="{{formData.realName}}"
          data-field="realName"
          bindinput="onFormInput"
        />
      </view>
      
      <view class="form-item">
        <text class="form-label">学号/工号</text>
        <input 
          class="form-input" 
          placeholder="请输入学号或工号"
          value="{{formData.studentId}}"
          data-field="studentId"
          bindinput="onFormInput"
        />
      </view>
      
      <view class="form-item">
        <text class="form-label">邮箱</text>
        <input 
          class="form-input" 
          placeholder="请输入邮箱"
          value="{{formData.email}}"
          data-field="email"
          bindinput="onFormInput"
        />
      </view>
      
      <view class="form-item">
        <text class="form-label">手机号</text>
        <input 
          class="form-input" 
          placeholder="请输入手机号"
          value="{{formData.phone}}"
          data-field="phone"
          bindinput="onFormInput"
        />
      </view>
      
      <view class="form-item">
        <text class="form-label">角色</text>
        <picker bindchange="onRoleChange" value="{{roleOptions.findIndex(r => r.value === formData.role)}}" range="{{roleOptions}}" range-key="label">
          <view class="form-picker">
            <text>{{roleOptions.find(r => r.value === formData.role).label}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
      
      <view class="form-item">
        <text class="form-label">状态</text>
        <picker bindchange="onStatusChange" value="{{statusOptions.findIndex(s => s.value === formData.status)}}" range="{{statusOptions}}" range-key="label">
          <view class="form-picker">
            <text>{{statusOptions.find(s => s.value === formData.status).label}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>
    
    <view class="modal-footer">
      <view class="btn-cancel" bindtap="closeUserModal">取消</view>
      <view class="btn-confirm" bindtap="saveUser">保存</view>
    </view>
  </view>

  <!-- 重置密码弹窗 -->
  <view class="modal-mask" wx:if="{{showPasswordModal}}" bindtap="closePasswordModal"></view>
  <view class="modal password-modal {{showPasswordModal ? 'show' : ''}}">
    <view class="modal-header">
      <text class="modal-title">重置密码</text>
      <view class="modal-close" bindtap="closePasswordModal">✕</view>
    </view>
    
    <view class="modal-body">
      <view class="password-tips">
        <text>正在为 <text class="highlight">{{currentUser?.realName}}</text> 重置密码</text>
      </view>
      
      <view class="form-item">
        <text class="form-label">新密码</text>
        <input 
          class="form-input" 
          type="password"
          placeholder="请输入新密码（至少6位）"
          value="{{newPassword}}"
          data-field="newPassword"
          bindinput="onPasswordInput"
        />
      </view>
      
      <view class="form-item">
        <text class="form-label">确认密码</text>
        <input 
          class="form-input" 
          type="password"
          placeholder="请再次输入新密码"
          value="{{confirmPassword}}"
          data-field="confirmPassword"
          bindinput="onPasswordInput"
        />
      </view>
    </view>
    
    <view class="modal-footer">
      <view class="btn-cancel" bindtap="closePasswordModal">取消</view>
      <view class="btn-confirm" bindtap="resetPassword">确认重置</view>
    </view>
  </view>
</view>
