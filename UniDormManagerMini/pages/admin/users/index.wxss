/* pages/admin/users/index.wxss */

/* 页面标题 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-title {
  flex: 1;
}

.user-count {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.add-icon {
  font-size: 32rpx;
  line-height: 1;
}

/* 搜索栏 */
.search-section {
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: var(--text-tertiary);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 筛选栏 */
.filter-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
}

.filter-group {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.filter-item {
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.filter-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* 用户列表 */
.user-list {
  min-height: 400rpx;
}

.user-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 用户卡片 */
.user-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.user-main {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.role-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.role-tag.student {
  background: rgba(59, 130, 246, 0.1);
  color: #3b82f6;
}

.role-tag.maintenance {
  background: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
}

.role-tag.dorm_manager {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.role-tag.building_admin {
  background: rgba(139, 92, 246, 0.1);
  color: #8b5cf6;
}

.role-tag.logistics_admin {
  background: rgba(236, 72, 153, 0.1);
  color: #ec4899;
}

.role-tag.system_admin {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

.status-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-tag.active {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

.status-tag.disabled {
  background: rgba(107, 114, 128, 0.1);
  color: var(--text-tertiary);
}

.info-row.secondary {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.user-id,
.user-username,
.user-phone {
  color: var(--text-secondary);
}

.divider {
  color: var(--gray-300);
}

.info-row.tertiary {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 操作按钮 */
.user-actions {
  display: flex;
  gap: 12rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--gray-100);
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.edit {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.action-btn.password {
  background: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
}

.action-btn.disable {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
}

.action-btn.enable {
  background: rgba(16, 185, 129, 0.1);
  color: #10b981;
}

/* 加载更多 */
.load-more {
  padding: 32rpx 0;
}

.load-more-btn {
  text-align: center;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.no-more {
  text-align: center;
  padding: 32rpx 0;
  color: var(--text-tertiary);
  font-size: 24rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 998;
}

.modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 999;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal.show {
  transform: translateY(0);
}

.password-modal {
  max-height: 60vh;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid var(--gray-100);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--gray-100);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-tertiary);
}

.modal-body {
  padding: 32rpx;
  overflow-y: auto;
  flex: 1;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--gray-100);
}

/* 表单样式 */
.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: var(--gray-50);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--gray-50);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.picker-arrow {
  color: var(--text-tertiary);
  font-size: 32rpx;
}

/* 密码重置 */
.password-tips {
  padding: 20rpx 24rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 16rpx;
  margin-bottom: 28rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.highlight {
  color: #667eea;
  font-weight: 600;
}

/* 弹窗按钮 */
.btn-cancel,
.btn-confirm {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.btn-cancel {
  background: var(--gray-100);
  color: var(--text-secondary);
}

.btn-confirm {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.btn-cancel:active,
.btn-confirm:active {
  transform: scale(0.96);
}

/* 加载样式 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}
