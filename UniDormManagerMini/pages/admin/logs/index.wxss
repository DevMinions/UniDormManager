/* pages/admin/logs/index.wxss */

/* 页面标题 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-title {
  flex: 1;
}

.log-count {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.export-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.4);
}

/* 搜索栏 */
.search-section {
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: var(--text-tertiary);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 筛选栏 */
.filter-section {
  margin-bottom: 20rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  margin-right: 12rpx;
  transition: all 0.2s ease;
}

.filter-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* 日期筛选 */
.date-filter-section {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  padding-bottom: 4rpx;
}

.date-filter {
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.date-filter.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* 日志列表 */
.log-list {
  min-height: 400rpx;
}

.log-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 日志项 */
.log-item {
  display: flex;
  gap: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.log-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.log-icon.user {
  background: rgba(59, 130, 246, 0.1);
}

.log-icon.room {
  background: rgba(16, 185, 129, 0.1);
}

.log-icon.repair {
  background: rgba(245, 158, 11, 0.1);
}

.log-icon.notice {
  background: rgba(236, 72, 153, 0.1);
}

.log-icon.checkin {
  background: rgba(139, 92, 246, 0.1);
}

.log-icon.checkout {
  background: rgba(107, 114, 128, 0.1);
}

.log-icon.settings {
  background: rgba(239, 68, 68, 0.1);
}

.log-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.log-action {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.log-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.log-description {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.log-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.log-operator {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 加载更多 */
.load-more {
  padding: 32rpx 0;
}

.load-more-btn {
  text-align: center;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.no-more {
  text-align: center;
  padding: 32rpx 0;
  color: var(--text-tertiary);
  font-size: 24rpx;
}

/* 加载样式 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}
