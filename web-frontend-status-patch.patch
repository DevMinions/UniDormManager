From: UniDormManager Backend API Update
Date: Sun, 15 Mar 2026 08:44:00 +0000
Subject: [PATCH] Web Frontend: Adapt to new backend status values

This patch updates the Web frontend to work with the new backend API
that returns lowercase status values.

Changes:
- Repair status: 'Pending'/'In Progress' -> 'pending'/'processing'
- Inspection status: 'Good'/'Fair' -> 'good'/'fair'
- Added backward compatibility in status utility functions

---
 UniDormManagerWeb/src/test/mockData.ts   |  8 ++++----
 UniDormManagerWeb/src/test/utils.test.ts | 26 ++++++++++++++++++++++-
 2 files changed, 29 insertions(+), 5 deletions(-)

diff --git a/UniDormManagerWeb/src/test/mockData.ts b/UniDormManagerWeb/src/test/mockData.ts
index 17316e9..e7a7832 100644
--- a/UniDormManagerWeb/src/test/mockData.ts
+++ b/UniDormManagerWeb/src/test/mockData.ts
@@ -84,7 +84,7 @@ export const mockRepairs = [
     id: '1',
     title: '水龙头漏水',
     description: '浴室洗脸盆水龙头持续漏水',
-    status: 'Pending' as const,
+    status: 'pending' as const,
     date: '2024-01-15',
     roomNumber: 'A-101',
     priority: 'High' as const,
@@ -93,7 +93,7 @@ export const mockRepairs = [
     id: '2',
     title: '灯泡损坏',
     description: '宿舍灯泡不亮',
-    status: 'In Progress' as const,
+    status: 'processing' as const,
     date: '2024-01-14',
     roomNumber: 'A-102',
     priority: 'Medium' as const,
@@ -163,7 +163,7 @@ export const mockInspections = [
     inspector: '张老师',
     checkDate: '2024-01-15',
     overallScore: 92,
-    status: 'Good' as const,
+    status: 'good' as const,
     comment: '整体卫生良好',
     createdAt: '2024-01-15T10:00:00Z',
     updatedAt: '2024-01-15T10:00:00Z',
@@ -175,7 +175,7 @@ export const mockInspections = [
     inspector: '张老师',
     checkDate: '2024-01-15',
     overallScore: 78,
-    status: 'Fair' as const,
+    status: 'fair' as const,
     comment: '需要加强卫生管理',
     createdAt: '2024-01-15T11:00:00Z',
     updatedAt: '2024-01-15T11:00:00Z',
diff --git a/UniDormManagerWeb/src/test/utils.test.ts b/UniDormManagerWeb/src/test/utils.test.ts
index e6a292c..f4a3e8b 100644
--- a/UniDormManagerWeb/src/test/utils.test.ts
+++ b/UniDormManagerWeb/src/test/utils.test.ts
@@ -31,6 +31,7 @@ export const formatDate = (dateString: string): string => {
 // Utility function to get status color
 export const getStatusColor = (status: string): string => {
   const colors: Record<string, string> = {
+    // 旧格式（兼容）
     Active: 'green',
     Inactive: 'gray',
     Suspended: 'red',
@@ -44,12 +45,21 @@ export const getStatusColor = (status: string): string => {
     Excellent: 'green',
     Good: 'blue',
     Fair: 'yellow',
     Poor: 'red',
+    // 新格式（小写）
+    pending: 'yellow',
+    processing: 'blue',
+    completed: 'green',
+    good: 'blue',
+    fair: 'yellow',
+    poor: 'red',
+    excellent: 'green',
   };
   return colors[status] || 'gray';
 };
 
 // Utility function to get status text
 export const getStatusText = (status: string): string => {
   const texts: Record<string, string> = {
+    // 旧格式（兼容）
     Active: '活跃',
     Inactive: '未激活',
     Suspended: '暂停',
@@ -63,6 +73,15 @@ export const getStatusText = (status: string): string => {
     Excellent: '优秀',
     Good: '良好',
     Fair: '一般',
     Poor: '较差',
+    // 新格式（小写）
+    pending: '待处理',
+    processing: '处理中',
+    completed: '已完成',
+    good: '良好',
+    fair: '一般',
+    poor: '较差',
+    excellent: '优秀',
   };
   return texts[status] || status;
 };
